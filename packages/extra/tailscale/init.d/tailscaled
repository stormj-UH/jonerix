#!/bin/openrc-run
# OpenRC service script for tailscaled - Tailscale node agent.

name="tailscaled"
description="Tailscale node agent"

: "${PORT:=41641}"
: "${FLAGS:=}"
[ -r /etc/default/tailscaled ] && . /etc/default/tailscaled

command="/bin/tailscaled"
command_args="--state=/var/lib/tailscale/tailscaled.state --socket=/run/tailscale/tailscaled.sock --port=${PORT} ${FLAGS}"
command_background="yes"
pidfile="/run/tailscaled.pid"
output_log="/var/log/tailscaled.log"
error_log="/var/log/tailscaled.log"

depend() {
    need net
    use ntpd logger dns
    after firewall ntpd
}

_load_mod() {
    [ -n "$1" ] || return 0
    grep -q "^$1 " /proc/modules 2>/dev/null && return 0
    local kver="$(uname -r)"
    local mod
    for ext in .ko.xz .ko; do
        mod=$(find "/lib/modules/${kver}" -type f -name "$1${ext}" 2>/dev/null | head -1)
        [ -n "$mod" ] && break
    done
    [ -z "$mod" ] && return 0
    case "$mod" in
        *.xz) xzcat "$mod" > /tmp/.tsd-mod.ko 2>/dev/null && insmod /tmp/.tsd-mod.ko 2>/dev/null ;;
        *)    insmod "$mod" 2>/dev/null ;;
    esac
    rm -f /tmp/.tsd-mod.ko
}

start_pre() {
    checkpath -d -m 0700 /var/lib/tailscale
    checkpath -d -m 0755 /run/tailscale
    checkpath -d -m 0750 /var/cache/tailscale

    if [ ! -c /dev/net/tun ]; then
        [ -d /dev/net ] || mkdir -p /dev/net
        mknod /dev/net/tun c 10 200 2>/dev/null || true
        chmod 0666 /dev/net/tun 2>/dev/null || true
    fi

    for m in tun nfnetlink nf_tables nf_defrag_ipv4 nf_defrag_ipv6 \
             nf_conntrack nf_nat nft_chain_nat nft_nat nft_masq nft_ct \
             nft_reject nft_fib nft_fib_inet nft_compat; do
        _load_mod "$m"
    done
}

stop_post() {
    /bin/tailscaled --cleanup >/dev/null 2>&1 || true
}
