#!/bin/openrc-run
# tailscale-up — ensure the tailscale tunnel is up once tailscaled
# is running. Idempotent: if the node is already logged in (state
# persisted in /var/lib/tailscale), `tailscale up` with no args
# just confirms the tunnel without prompting.
#
# Designed to run in the `default` runlevel after `tailscaled` has
# started in `boot`. Waits for the control socket to appear before
# issuing the command so we don't race tailscaled startup.

description="Bring the tailscale tunnel up after tailscaled starts"
command="/bin/true"

depend() {
    need tailscaled
    after net
    keyword -jail -prefix -vserver
}

start_pre() {
    i=0
    while [ $i -lt 15 ] && [ ! -S /run/tailscale/tailscaled.sock ]; do
        sleep 1
        i=$((i+1))
    done
}

start() {
    ebegin "Bringing tailscale tunnel up"
    /bin/tailscale up 2>&1
    eend $?
}

stop() {
    ebegin "Bringing tailscale tunnel down"
    /bin/tailscale down 2>&1
    eend 0
}
