# jonerix x86_64 kernel configuration fragment
#
# This is a CONFIG FRAGMENT, not a full .config. It is merged on top of
# defconfig using scripts/kconfig/merge_config.sh. Only settings that differ
# from defconfig or that must be explicitly enforced are listed here.
#
# Design goals:
#   - UEFI EFISTUB boot (no separate bootloader needed)
#   - Core storage drivers built-in (no initramfs required)
#   - Core network drivers built-in
#   - ext4 and vfat built-in (root FS + EFI partition)
#   - Container support (namespaces, cgroups v2, overlay FS)
#   - Security hardening (KASLR, stack protector, KPTI)
#   - Serial/console support for headless servers
#   - Module compression with zstd (matches jonerix's compression preference)

# ============================================================
# UEFI / EFI STUB — boot directly from UEFI firmware, no GRUB
# ============================================================
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_MIXED=n
# Unified Kernel Image support (kernel + cmdline + initrd in one EFI binary)
CONFIG_EFI_ZBOOT=y
CONFIG_CMDLINE_BOOL=n

# ============================================================
# STORAGE — built-in so no initramfs is needed
# ============================================================
# AHCI (SATA)
CONFIG_ATA=y
CONFIG_ATA_VERBOSE_ERROR=y
CONFIG_SATA_AHCI=y
CONFIG_ATA_PIIX=y

# NVMe
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_MULTIPATH=y

# virtio-blk (VM / QEMU / cloud)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_SCSI=y

# SCSI (needed by virtio-scsi and for USB mass storage)
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_VIRTIO=y

# USB storage (live boot media, USB SATA docks)
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y

# ============================================================
# FILESYSTEMS — built-in for initramfs-free boot
# ============================================================
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y

# vfat / FAT32 (EFI System Partition)
CONFIG_FAT_FS=y
CONFIG_MSDOS_FS=y
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_CODEPAGE=437
CONFIG_FAT_DEFAULT_IOCHARSET="iso8859-1"
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y

# tmpfs (required for /run, /tmp in jonerix)
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y

# proc / sysfs / devtmpfs (required)
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# overlayfs (container layers via containerd/nerdctl)
CONFIG_OVERLAY_FS=y

# ============================================================
# NETWORKING — built-in common drivers
# ============================================================
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y

# e1000e (Intel GbE — common on servers and Intel NUCs)
CONFIG_E1000E=y

# igc (Intel 2.5GbE I225/I226 — modern Intel desktops/servers)
CONFIG_IGC=y

# virtio-net (VM / QEMU / cloud)
CONFIG_VIRTIO_NET=y

# ixgbe (Intel 10GbE — common in rack servers)
CONFIG_IXGBE=m

# tun/tap (used by container networking and VPNs)
CONFIG_TUN=y

# veth (virtual Ethernet pairs for containers)
CONFIG_VETH=y

# bridge (container networking)
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y

# nftables (firewall; iptables-nft translates to nf_tables)
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NFT_COUNTER=y
CONFIG_NFT_CT=y
CONFIG_NFT_LOG=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_NAT=y
CONFIG_NFT_REJECT=y

# ============================================================
# CONTAINERS — namespaces, cgroups v2, overlayfs
# ============================================================
# Namespaces (all required for OCI containers via runc/containerd)
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_CGROUP_NS=n

# cgroups v2 (unified hierarchy — required by containerd, nerdctl, runc)
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_RDMA=y
CONFIG_CGROUP_MISC=y
# Unified cgroup v2 hierarchy
CONFIG_CGROUP_BPF=y

# seccomp (used by runc/containerd for syscall filtering)
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# ============================================================
# SECURITY HARDENING
# ============================================================
# KASLR — randomize kernel load address
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y

# Stack protector (matches jonerix userland: -fstack-protector-strong)
CONFIG_CC_STACKPROTECTOR_STRONG=y
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y

# KPTI — kernel page table isolation (Meltdown mitigation)
CONFIG_PAGE_TABLE_ISOLATION=y

# SMEP / SMAP enforcement (hardware, no config needed; confirm enabled)
CONFIG_X86_SMAP=y
CONFIG_X86_UMIP=y

# Retpoline (Spectre v2 mitigation)
CONFIG_RETPOLINE=y

# Harden usercopy (detect kernel/user copy overflows)
CONFIG_HARDENED_USERCOPY=y
CONFIG_HARDENED_USERCOPY_FALLBACK=n

# Restrict /dev/mem and /dev/kmem
CONFIG_STRICT_DEVMEM=y
CONFIG_IO_STRICT_DEVMEM=y

# dmesg restriction (pairs with kernel.dmesg_restrict=1 sysctl in jonerix)
CONFIG_SECURITY_DMESG_RESTRICT=n

# Lock down /proc/kcore
CONFIG_PROC_PAGE_MONITOR=y

# BPF JIT hardening
CONFIG_BPF_JIT_ALWAYS_ON=n
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y

# ============================================================
# CONSOLE / SERIAL — headless server support
# ============================================================
# Virtual console
CONFIG_VT=y
CONFIG_CONSOLE_TRANSLATIONS=y
CONFIG_VT_CONSOLE=y
CONFIG_VGA_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE=y

# Serial console (ttyS0 for headless access / Limine serial output)
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_PCI=y
# Number of 8250 runtime UARTs; 4 covers ttyS0-ttyS3
CONFIG_SERIAL_8250_NR_UARTS=4
CONFIG_SERIAL_8250_RUNTIME_UARTS=4

# EFI framebuffer (UEFI GOP / VESA)
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_DRM_SIMPLEDRM=y

# ============================================================
# POWER / CLOCK
# ============================================================
CONFIG_PM=y
CONFIG_ACPI=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_X86_ACPI_CPUFREQ=y

# ============================================================
# MODULE COMPRESSION
# Prefer zstd (matches jonerix's compression preference for .jpkg archives)
# ============================================================
CONFIG_MODULE_COMPRESS_ZSTD=y
CONFIG_MODULE_COMPRESS_NONE=n
CONFIG_MODULE_COMPRESS_GZIP=n
CONFIG_MODULE_COMPRESS_XZ=n

# ============================================================
# MISC REQUIRED / USEFUL
# ============================================================
# POSIX message queues (used by some container runtimes)
CONFIG_POSIX_MQUEUE=y

# inotify (used by containerd file-watcher)
CONFIG_INOTIFY_USER=y

# epoll (used by nearly everything)
CONFIG_EPOLL=y

# Signalfd / timerfd / eventfd
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y

# Futex (required for pthreads)
CONFIG_FUTEX=y

# UNIX domain sockets (used by containerd, OpenRC, logging)
CONFIG_UNIX=y

# Crypto (OpenSSL, TLS, WireGuard)
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_AES_NI_INTEL=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_CHACHA20POLY1305=y
CONFIG_CRYPTO_CURVE25519=y

# WireGuard (in-kernel VPN, used by Tailscale/headscale)
CONFIG_WIREGUARD=m

# ============================================================
# JONERIX BRANDING — bake the distro into the kernel release string
# ============================================================
# CONFIG_LOCALVERSION is appended to kernelversion to form
# `uname -r`. Combined with CONFIG_LOCALVERSION_AUTO=n (the default
# for non-git builds, but explicit here) this makes /proc/version,
# /proc/sys/kernel/osrelease, and uname(2) all surface
# "-jonerix-1.2.2" so a kernel-side caller can tell it's running on
# a jonerix system without reading /etc/os-release.
CONFIG_LOCALVERSION="-jonerix-1.2.2"
CONFIG_LOCALVERSION_AUTO=n
