# /etc/zshrc — jonerix system-wide zsh interactive config

[ -n "${LANG-}" ] || export LANG=C.UTF-8
[ -n "${LC_CTYPE-}" ] || export LC_CTYPE=$LANG

# /etc/profile-style fallback: a missing TERM (e.g. when the env was
# stripped by `login` without `-p`) leaves ncurses in dumb mode and
# zsh's Backspace bindings break. Default to "linux" for tty1-class
# consoles, otherwise keep whatever was forwarded.
[ -n "${TERM-}" ] || export TERM=linux

# NOTE: compinit is intentionally NOT called here. On jonerix/musl,
# compinit's dumpfile path wedges in ppoll(NULL, 0, ...). Reproducible
# 2026-04-24 by sourcing /etc/zshrc with TERM=linux — zsh hangs
# entirely. Re-enable when the upstream musl/zsh interaction is
# fixed; until then, completion is opt-in via the user's own .zshrc.

# Make sure Backspace + Delete work on every terminal we ship with.
# On a Linux VC (TERM=linux) the kernel emits DEL (\x7f) for Backspace,
# but `bindkey -e` only binds it when emacs mode is the active keymap
# at zle startup. Force emacs mode + explicit binds so the HDMI console
# behaves the same as an SSH session.
bindkey -e
bindkey '^?'    backward-delete-char   # Backspace
bindkey '^H'    backward-delete-char   # some serial paths
bindkey '^[[3~' delete-char            # Forward Delete
bindkey '^[[1~' beginning-of-line      # Home
bindkey '^[[H'  beginning-of-line
bindkey '^[[4~' end-of-line            # End
bindkey '^[[F'  end-of-line
bindkey '^[[A'  up-line-or-history     # Up
bindkey '^[[B'  down-line-or-history   # Down

HISTFILE=${ZDOTDIR:-$HOME}/.zsh_history
HISTSIZE=1000
SAVEHIST=1000
setopt APPEND_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt INTERACTIVE_COMMENTS

# Prompt:
#   [user@host HH:MM:SS cwd] %     (non-root)
#   [user@host HH:MM:SS cwd] #     (root)
#
# Brackets are blue, everything inside (and the trailing sigil) is white.
# `%~` shows $HOME as `~`. `%%` is the escape for a literal `%` since
# bare `%` is zsh's prompt-syntax marker. `%(!.#.%%)` selects `#` for
# root (uid 0 == privileged) and `%` for everyone else. `%f` resets
# colour back to default.
#
# %F{blue}/%F{white} are named colours that render on every terminal
# advertising >= 8 colours, including the Linux VC. We deliberately
# do NOT branch on `tput colors` here — both 8-colour and 256-colour
# terminals see the same palette, no surprise differences across
# HDMI / SSH / xterm sessions.
PROMPT='%F{blue}[%F{white}%n@%m %D{%H:%M:%S} %~%F{blue}]%F{white} %(!.#.%%)%f '
