# dhcpcd hook: kick netconsole-trace once eth0 has an IPv4 lease.
#
# Background: /etc/init.d/netconsole-trace used to run in the `boot`
# runlevel. At that point dhcpcd had only been START'd — no lease yet —
# and `insmod netconsole netconsole=6666@/eth0,6666@10.0.0.3/<mac>`
# against an address-less eth0 fails with -EDESTADDRREQ ("Destination
# address required") from the kernel's netpoll setup. See
# /var/log/reboot-trace/netconsole-insmod.err for the historical error.
#
# This hook fires on IPv4 lease events (BOUND / RENEW / REBIND / REBOOT /
# INFORM) for the netconsole target interface and runs the service
# start(). Other reasons and other interfaces are no-ops.
#
# Idempotent: the init.d script short-circuits when `netconsole` is
# already in /proc/modules, so renewal events don't re-load the module.
#
# POSIX-sh / mksh-safe. Sourced by /libexec/dhcpcd-run-hooks, so uses
# `return` (not `exit`) to yield back to the runner.

: "${NETCONSOLE_DEV:=eth0}"

# Only IPv4 lease events — the kernel src-ip lookup runs against an
# IPv4 address; a v6 lease doesn't help.
case "$reason" in
	BOUND|RENEW|REBIND|REBOOT|INFORM) ;;
	*) return 0 ;;
esac

# Only for the interface we'll stream kernel logs out of.
[ "$interface" = "$NETCONSOLE_DEV" ] || return 0

# Only when we actually have an address.
[ -n "$new_ip_address" ] || return 0

# Already loaded? Nothing to do.
if [ -r /proc/modules ] && grep -q '^netconsole ' /proc/modules; then
	return 0
fi

# Fire asynchronously so a slow insmod (module read from /lib/modules on
# SD card) doesn't stall dhcpcd's event loop. service_command is a
# dhcpcd-hook helper; logger-tagged so the attempt shows up in syslog.
(
	service_command netconsole-trace start 2>&1 |
		logger -t netconsole-hook -p daemon.info
) &
