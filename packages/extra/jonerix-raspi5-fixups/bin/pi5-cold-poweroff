#!/bin/mksh
# pi5-cold-poweroff - do one full power-cut shutdown without permanently
# changing EEPROM POWER_OFF_ON_HALT.
#
# Pairs with /etc/init.d/pi5-cold-shutdown: arms that service in both
# the shutdown and default runlevels, then immediately invokes the
# orderly OpenRC poweroff.  OpenRC enters the shutdown runlevel,
# starts pi5-cold-shutdown which flips POWER_OFF_ON_HALT=1 in EEPROM,
# and only then issues the kernel poweroff.  The bootloader sees =1
# and cuts SoC power fully (instead of the ~0.5 W standby that
# POWER_OFF_ON_HALT=0 produces).  After you physically wake the Pi
# again, pi5-cold-shutdown's boot-time start() restores =0 and
# removes itself from both runlevels.
#
# Usage:
#     sudo pi5-cold-poweroff [-d DELAY]
#
# The wrapper is a thin one-liner over openrc-shutdown so you can use
# it just like /bin/poweroff; we don't add a -f fallback because the
# whole point is to go through openrc-shutdown so pi5-cold-shutdown
# fires before the halt.
#
# To CANCEL after running this, before the halt completes:
#     sudo openrc-shutdown -c
#     sudo rc-update del pi5-cold-shutdown shutdown
#     sudo rc-update del pi5-cold-shutdown default
#
# Part of jonerix - MIT License

set -e

delay=

while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help)
            echo "usage: pi5-cold-poweroff [-d DELAY]"
            echo "Cold (full-power-cut) shutdown for Raspberry Pi 5."
            exit 0
            ;;
        -d)
            shift
            delay=${1:-}
            ;;
        -d*)
            delay=${1#-d}
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "pi5-cold-poweroff: unsupported argument: $1" >&2
            exit 2
            ;;
    esac
    shift
done

if [ "$(id -u)" -ne 0 ]; then
    echo "pi5-cold-poweroff: must run as root (needs /dev/vcio + rc-update + openrc-shutdown)" >&2
    exit 1
fi

if [ ! -f /etc/init.d/pi5-cold-shutdown ]; then
    echo "pi5-cold-poweroff: /etc/init.d/pi5-cold-shutdown missing — reinstall jonerix-raspi5-fixups" >&2
    exit 1
fi

# Arm the service in both runlevels.  rc-update is idempotent on
# duplicate adds and doesn't fail if the link already exists.
rc-update add pi5-cold-shutdown shutdown 2>/dev/null || true
rc-update add pi5-cold-shutdown default  2>/dev/null || true

if [ -n "$delay" ]; then
    sleep "$delay" || exit 2
fi

exec /bin/openrc-shutdown -p now
