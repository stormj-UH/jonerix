#!/bin/mksh
# reboot-openrc - Pi 5-safe reboot wrapper for OpenRC systems.
#
# Plain toybox reboot leaves some Pi 5 systems powered but not booting
# again after OpenRC has stopped services and remounted root read-only.
# OpenRC's native reboot path (`openrc-shutdown -r now`) does return
# correctly on the affected hardware, so this wrapper backs /bin/reboot
# on Pi 5 installs.

delay=
force=0

while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help)
            echo "usage: reboot [-d DELAY] [-f] [-n]"
            echo "OpenRC-backed reboot wrapper for Raspberry Pi 5."
            exit 0
            ;;
        -d)
            shift
            delay=${1:-}
            ;;
        -d*)
            delay=${1#-d}
            ;;
        -f)
            force=1
            ;;
        -n)
            # OpenRC performs the orderly shutdown path; keep this
            # accepted for toybox compatibility but don't skip sync.
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "reboot: unsupported argument: $1" >&2
            exit 2
            ;;
    esac
    shift
done

if [ "$force" = 1 ]; then
    exec /bin/toybox reboot -f
fi

if [ -n "$delay" ]; then
    sleep "$delay" || exit 2
fi

exec /bin/openrc-shutdown -r now
