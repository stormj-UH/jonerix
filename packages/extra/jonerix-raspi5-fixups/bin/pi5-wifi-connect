#!/bin/sh
# pi5-wifi-connect — interactive helper to add a WPA2 network to the
# Pi 5's onboard wlan0 and bring up wpa_supplicant.
#
# jonerix's distribution-default config never knows your SSID / PSK.
# This script writes them to /etc/wpa_supplicant/wpa_supplicant-wlan0.conf
# (mode 600, root-owned), starts the wpa_supplicant_wlan0 OpenRC
# service if it's not already running, and pokes dhcpcd so it picks
# up the new interface.
#
# Usage:
#   sudo pi5-wifi-connect [SSID]
#   sudo pi5-wifi-connect --remove SSID
#   sudo pi5-wifi-connect --list
#
# When SSID is omitted, lists nearby networks and lets the user pick.
# PSK is read with `read -s` so it never appears in the shell history.
#
# POSIX shell — runs on dash/ash/mksh. Part of jonerix-raspi5-fixups.

set -eu

CONF=/etc/wpa_supplicant/wpa_supplicant-wlan0.conf

msg()  { printf '==> %s\n' "$*"; }
warn() { printf '!!  %s\n' "$*" >&2; }
die()  { printf 'error: %s\n' "$*" >&2; exit 1; }

[ "$(id -u)" -eq 0 ] || die "must run as root"

# ── Sanity: wlan0 exists, wpa_supplicant + wpa_passphrase are on PATH ──
[ -d /sys/class/net/wlan0 ] \
    || die "no wlan0 — start the pi5-wifi service first (rc-service pi5-wifi start)"
command -v wpa_supplicant >/dev/null 2>&1 \
    || die "wpa_supplicant not installed (jpkg install wpa_supplicant)"

ensure_conf() {
    if [ ! -e "$CONF" ]; then
        mkdir -p "$(dirname "$CONF")"
        cat > "$CONF" <<'EOF'
# /etc/wpa_supplicant/wpa_supplicant-wlan0.conf
# Generated by pi5-wifi-connect. Add networks via:
#   sudo pi5-wifi-connect <SSID>
ctrl_interface=DIR=/var/run/wpa_supplicant GROUP=wheel
update_config=1
country=US
EOF
        chmod 600 "$CONF"
    fi
}

list_known() {
    grep -E '^[[:space:]]*ssid=' "$CONF" 2>/dev/null \
        | sed -E 's/^[[:space:]]*ssid="(.*)"$/  \1/'
}

# ── List networks the chip can see right now ───────────────────────
scan_visible() {
    msg "Scanning..."
    # Make sure wpa_supplicant is alive so wpa_cli can drive it.
    if ! wpa_cli -i wlan0 ping >/dev/null 2>&1; then
        wpa_supplicant -B -i wlan0 -D nl80211 -c "$CONF" >/dev/null 2>&1 || true
        sleep 2
    fi
    wpa_cli -i wlan0 scan >/dev/null
    sleep 4
    wpa_cli -i wlan0 scan_results 2>/dev/null \
        | awk 'NR>1 && $5 != "" {
                printf "  %-32s  signal=%-4s  flags=%s\n", $5, $3, $4
            }' \
        | sort -k1
}

# ── Subcommand dispatch ────────────────────────────────────────────
case "${1:-}" in
    --list)
        ensure_conf
        echo "Configured networks:"
        list_known || echo "  (none)"
        echo
        echo "Visible networks:"
        scan_visible
        exit 0
        ;;
    --remove)
        [ $# -ge 2 ] || die "--remove SSID"
        SSID="$2"
        ensure_conf
        # Strip any network={ ... ssid="$SSID" ... } block
        awk -v target="\"$SSID\"" '
            /^network={/ { buf=$0; collecting=1; matched=0; next }
            collecting {
                buf = buf "\n" $0
                if ($1 ~ /ssid=/ && $1 ~ target) matched=1
                if ($0 ~ /^\}/) {
                    if (!matched) print buf
                    collecting=0; buf=""; matched=0
                }
                next
            }
            { print }
        ' "$CONF" > "$CONF.new"
        mv "$CONF.new" "$CONF"
        chmod 600 "$CONF"
        msg "Removed $SSID. Run \`rc-service wpa_supplicant_wlan0 reload\` to apply."
        exit 0
        ;;
esac

# ── Interactive add ────────────────────────────────────────────────
ensure_conf
SSID="${1:-}"
if [ -z "$SSID" ]; then
    echo
    echo "Visible networks:"
    scan_visible
    echo
    printf "SSID to connect to: "
    read SSID
fi
[ -n "$SSID" ] || die "no SSID"

# Read PSK without echo. Fall back to plain read on shells without -s.
printf "Passphrase for %s (will not echo): " "$SSID"
if ( /bin/sh -c 'read -s X' </dev/null ) >/dev/null 2>&1; then
    stty -echo
    read PSK
    stty echo
    echo
else
    read PSK
fi
[ -n "$PSK" ] || die "no passphrase"

# Generate the network={ } block. wpa_passphrase hashes the PSK so
# the cleartext doesn't sit on disk; it ships with wpa_supplicant.
TMP=$(mktemp)
chmod 600 "$TMP"
trap 'rm -f "$TMP"' EXIT

if command -v wpa_passphrase >/dev/null 2>&1; then
    wpa_passphrase "$SSID" "$PSK" \
        | grep -vE '^[[:space:]]*#' >> "$TMP" \
        || die "wpa_passphrase failed (passphrase too short? must be 8-63 chars)"
else
    # Fallback: store cleartext (still mode 600).
    cat >> "$TMP" <<EOF

network={
    ssid="$SSID"
    psk="$PSK"
    key_mgmt=WPA-PSK
    priority=1
}
EOF
fi

# Strip any existing block with the same SSID to avoid duplicates.
awk -v target="\"$SSID\"" '
    /^network={/ { buf=$0; collecting=1; matched=0; next }
    collecting {
        buf = buf "\n" $0
        if ($1 ~ /ssid=/ && $1 ~ target) matched=1
        if ($0 ~ /^\}/) {
            if (!matched) print buf
            collecting=0; buf=""; matched=0
        }
        next
    }
    { print }
' "$CONF" > "$CONF.new"
cat "$TMP" >> "$CONF.new"
mv "$CONF.new" "$CONF"
chmod 600 "$CONF"

msg "Wrote network block for '$SSID' to $CONF"

# ── Bring it up ────────────────────────────────────────────────────
if rc-service wpa_supplicant_wlan0 status >/dev/null 2>&1; then
    msg "Reloading wpa_supplicant_wlan0"
    rc-service wpa_supplicant_wlan0 reload >/dev/null 2>&1 \
        || rc-service wpa_supplicant_wlan0 restart >/dev/null 2>&1
else
    msg "Starting wpa_supplicant_wlan0"
    rc-service wpa_supplicant_wlan0 start
fi

# Tell dhcpcd to (re)bind the interface so we get an IP.
if command -v dhcpcd >/dev/null 2>&1; then
    dhcpcd --rebind wlan0 >/dev/null 2>&1 || dhcpcd wlan0 >/dev/null 2>&1 || true
fi

# Wait for association with a 30s budget.
msg "Waiting for association..."
i=0
while [ "$i" -lt 30 ]; do
    if wpa_cli -i wlan0 status 2>/dev/null | grep -q '^wpa_state=COMPLETED'; then
        break
    fi
    sleep 1
    i=$((i + 1))
done
echo
wpa_cli -i wlan0 status 2>/dev/null | head -10
echo
ip -4 addr show wlan0 | grep inet || warn "associated but no IPv4 yet (dhcpcd may still be probing)"
