#!/bin/sh
# pi5-rtc-battery-check — poll the Pi 5 RTC coin-cell voltage
# exposed by the rpi-rtc driver at /sys/class/rtc/rtc0/battery_voltage
# (microvolts) and log at an appropriate severity.
#
# Source references for the sysfs attribute + value units:
#   raspberrypi/linux drivers/rtc/rtc-rpi.c — `battery_voltage_show`
#       reads RTC_BBAT_VOLTS via the videocore mailbox; reported in
#       microvolts (same units as charging_voltage*).
#   raspberrypi/documentation computers/raspberry-pi/rtc.adoc —
#       documents the J5 battery connector, lists the official
#       rechargeable ML coin cell part, and confirms that "retention
#       time measures in months" at single-digit-µA backup current.
#
# Threshold rationale — measured in millivolts internally:
#
#   INFO ≤ 500 mV — the RP1 RTC's ADC reads essentially zero when
#         no cell is populated at J5. The driver's own charging
#         range reports as [1.3 V, 4.4 V] (see
#         /sys/class/rtc/rtc0/charging_voltage_min / _max, which in
#         the kernel come from RTC_BBAT_CHG_VOLTS_MIN /_MAX). A
#         reading well below the charging floor is the "no battery"
#         signal.
#
#   ERROR <  2000 mV — end-of-life cutoff for both the recommended
#         lithium-manganese rechargeable cells (Panasonic ML2032
#         datasheet, "Discharge voltage cut-off 2.0 V") and the
#         incompatible-but-frequently-installed primary CR2032
#         (Panasonic CR2032 datasheet, "Nominal 3.0 V, minimum
#         operating 2.0 V"). Below 2.0 V the ML cell is fully
#         discharged and the RTC can start miscounting / stopping
#         at the next power loss.
#
#   WARN  <  2400 mV — the knee of the ML2032 / CR2032 discharge
#         curves. Both cells sit within ~100 mV of nominal for the
#         bulk of their capacity, then drop sharply from ~2.5 V
#         down to the 2.0 V cutoff inside the final few percent.
#         Panasonic's published curves put this tail at roughly
#         3–6 weeks of typical RTC-load service, so hitting
#         2.4 V is the "schedule a replacement in the next month"
#         signal.
#
#   OK    ≥ 2400 mV — healthy. Silent by default; `-v` still logs.
#
# All thresholds are dB-conservative relative to the RP1 itself:
# the RP1 datasheet does not publish an absolute VBAT operating
# minimum, but the charging_voltage_min sysfs value (1.3 V) is a
# floor for any RP1-supported cell, so the 2.0 V ERROR leaves
# 700 mV of margin against the silicon.
#
# Output goes to both stderr (for interactive runs) and `logger`
# (for cron / syslog forwarding). Exit status:
#   0 = OK / INFO (no action needed by the operator)
#   1 = WARN (replace soon)
#   2 = ERROR (replace now)
#
# Part of jonerix-raspi5-fixups — MIT License.

VERBOSE=0
case "${1:-}" in
    -v|--verbose) VERBOSE=1 ;;
esac

SRC=/sys/class/rtc/rtc0/battery_voltage
TAG=pi5-rtc-battery

# Helper: log at a given level both to stderr (with a visible
# prefix) and to syslog via logger, so the message lands in
# `/var/log/messages` for cron runs and on a human's terminal for
# interactive ones.
_log() {
    _lvl=$1; shift
    printf '[%s] %s\n' "$_lvl" "$*" >&2
    if command -v logger >/dev/null 2>&1; then
        case "$_lvl" in
            ERROR) logger -t "$TAG" -p user.err  -- "$*" ;;
            WARN)  logger -t "$TAG" -p user.warn -- "$*" ;;
            INFO)  logger -t "$TAG" -p user.info -- "$*" ;;
            OK)    logger -t "$TAG" -p user.info -- "$*" ;;
        esac
    fi
}

if [ ! -r "$SRC" ]; then
    _log INFO "no rpi-rtc battery_voltage sysfs attribute — driver not loaded or model lacks VBAT ADC"
    exit 0
fi

RAW=$(cat "$SRC" 2>/dev/null)
case "$RAW" in
    ''|*[!0-9]*)
        _log INFO "battery_voltage unreadable (content: '$RAW') — treating as no battery"
        exit 0
        ;;
esac

# Microvolts → millivolts (integer math; /bin/sh has no floats).
MV=$(( RAW / 1000 ))

# ≤ 500 mV is below the ADC noise floor for an unpopulated socket.
if [ "$MV" -le 500 ]; then
    _log INFO "no coin cell detected on RTC VBAT pin (reading ${MV} mV)"
    exit 0
fi

# Thresholds in millivolts.  Picked from RP1 datasheet minimum
# operating voltage (1.8 V) plus the ~1 month / 0.2 V typical drop
# observed on a loaded CR2032.
ERR_MV=2000
WARN_MV=2400

# Format back to volts with three decimals without relying on bc.
V_WHOLE=$(( MV / 1000 ))
V_FRAC=$(( MV % 1000 ))
VOLT=$(printf '%d.%03d' "$V_WHOLE" "$V_FRAC")

if [ "$MV" -lt "$ERR_MV" ]; then
    _log ERROR "RTC coin cell at ${VOLT} V — below ${ERR_MV} mV, clock likely to stop at next power loss. Replace battery."
    exit 2
fi

if [ "$MV" -lt "$WARN_MV" ]; then
    _log WARN "RTC coin cell at ${VOLT} V — below ${WARN_MV} mV, expected to fail within ~1 month. Schedule a replacement."
    exit 1
fi

# Healthy.
[ "$VERBOSE" = 1 ] && _log OK "RTC coin cell at ${VOLT} V (healthy, >= ${WARN_MV} mV)"
exit 0
