#!/bin/openrc-run
# pi5-cold-shutdown - boot-time restore service for pi5-cold-poweroff.
#
# Pairs with /usr/local/bin/pi5-cold-poweroff. The CLI does the EEPROM
# flip to POWER_OFF_ON_HALT=1 synchronously before halting, then drops
# this service into /etc/runlevels/default/ so that the very next boot
# restores POWER_OFF_ON_HALT=0 and unhooks itself. Future shutdowns
# are warm halts again until the user re-invokes pi5-cold-poweroff.
#
# The previous design (1.6.23) ran the EEPROM flip inside this
# service's start() during the shutdown runlevel. It was racy — OpenRC
# ran shutdown-runlevel services in parallel with mount-ro and the
# kernel was at the reboot syscall before the mailbox write returned,
# so the EEPROM never got =1 and the halt landed in standby. Moved
# the flip to the CLI in 1.6.24; this script now only handles the
# boot-side restore.
#
# Part of jonerix - MIT License

description="Restore POWER_OFF_ON_HALT=0 after a pi5-cold-poweroff cycle, then self-unhook"

depend() {
    keyword -jail -prefix -vserver
    need devfs
}

start() {
    ebegin "Restoring POWER_OFF_ON_HALT=0 after cold shutdown"
    if [ ! -x /usr/local/bin/pi5-wake-on-power ]; then
        ewarn "/usr/local/bin/pi5-wake-on-power not found; leaving EEPROM as-is"
        eend 0
        return 0
    fi
    /usr/local/bin/pi5-wake-on-power enable >/dev/null 2>&1
    if /usr/local/bin/pi5-wake-on-power 2>/dev/null \
            | grep -q "POWER_OFF_ON_HALT *= *0"; then
        rm -f /etc/runlevels/default/pi5-cold-shutdown
        einfo "POWER_OFF_ON_HALT=0 confirmed; pi5-cold-shutdown unhooked from boot."
        eend 0
    else
        ewarn "Could not confirm POWER_OFF_ON_HALT=0; will retry on next boot."
        ewarn "Manual recovery: sudo /usr/local/bin/pi5-wake-on-power enable"
        eend 0
    fi
}
