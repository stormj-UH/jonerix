#!/bin/openrc-run
# shadow-login — tty1 login prompt via shadow-getty.
#
# /bin/login is shadow login and reads LOGIN_TIMEOUT from /etc/login.defs.
# LOGIN_TIMEOUT 0 keeps an idle tty prompt up indefinitely. This service only
# loops after real logouts so tty1 comes back after an interactive session ends.

name="shadow-login"
description="shadow-utils login(1) on /dev/tty1 via shadow-getty"
pidfile="/run/shadow-login.pid"
logfile="/var/log/shadow-login.log"

start_pre() {
    [ -c /dev/tty1 ] || mknod /dev/tty1 c 4 1 2>/dev/null || true
    touch "$logfile" 2>/dev/null || true
}

is_running() {
    local pid
    [ -f "$pidfile" ] || return 1
    pid="$(cat "$pidfile" 2>/dev/null || true)"
    [ -n "$pid" ] || return 1
    [ -d "/proc/$pid" ]
}

start() {
    ebegin "Starting shadow-login"
    if is_running; then
        eend 0
        return 0
    fi
    /bin/mksh -c 'while :; do /bin/shadow-getty /dev/tty1; sleep 1; done' >>"$logfile" 2>&1 &
    echo $! > "$pidfile"
    eend 0
}

stop() {
    ebegin "Stopping shadow-login"
    if [ -f "$pidfile" ]; then
        loop_pid="$(cat "$pidfile" 2>/dev/null || true)"
        [ -n "$loop_pid" ] && kill "$loop_pid" 2>/dev/null || true
    fi
    pkill -x shadow-getty 2>/dev/null || true
    pkill -x login 2>/dev/null || true
    rm -f "$pidfile"
    eend 0
}

status() {
    if is_running; then
        einfo "shadow-login running (pid $(cat "$pidfile"))"
        return 0
    fi
    einfo "shadow-login not running"
    return 3
}

depend() {
    need localmount
    after devfs
    keyword -jail -prefix -vserver
}
