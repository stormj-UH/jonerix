+/* $(shell command) */
+static char *
+gnufunc_shell(const char *cmd)
+{
+	Buffer buf;
+	Buf_Init(&buf);
+	FILE *fp = popen(cmd, "r");
+	if (fp != NULL) {
+		int ch;
+		while ((ch = fgetc(fp)) != EOF) {
+			if (ch == '\n') {
+				/* collapse trailing newlines; internal → space */
+				int next = fgetc(fp);
+				if (next != EOF) {
+					Buf_AddByte(&buf, ' ');
+					ungetc(next, fp);
+				}
+			} else {
+				Buf_AddByte(&buf, (char)ch);
+			}
+		}
+		pclose(fp);
+	}
+	return Buf_DoneData(&buf);
+}
