+/* $(filter pattern...,text) */
+static char *
+gnufunc_filter(const char *patterns, const char *text)
+{
+	SubstringWords pats = Substring_Words(patterns, false);
+	SubstringWords words = Substring_Words(text, false);
+	Buffer buf;
+	Buf_Init(&buf);
+
+	for (size_t i = 0; i < words.len; i++) {
+		char *w = bmake_strldup(words.words[i].start,
+			Substring_Length(words.words[i]));
+		bool matched = false;
+		for (size_t j = 0; j < pats.len && !matched; j++) {
+			char *p = bmake_strldup(pats.words[j].start,
+				Substring_Length(pats.words[j]));
+			size_t stemLen;
+			if (gnufunc_pat_match(w, strlen(w), p, strlen(p), &stemLen))
+				matched = true;
+			free(p);
+		}
+		if (matched) {
+			if (buf.len > 0) Buf_AddByte(&buf, ' ');
+			Buf_AddStr(&buf, w);
+		}
+		free(w);
+	}
+	SubstringWords_Free(pats);
+	SubstringWords_Free(words);
+	return Buf_DoneData(&buf);
+}
