+/* ---- dispatch ---- */
+
+/*
+ * Try to evaluate a GNU make function call.
+ * name/nameLen is the parsed "variable name" (e.g. "sort foo bar baz").
+ * Returns an owned string with the result, or NULL if not a function.
+ */
+static char *
+GnuFunc_Eval(const char *name, size_t nameLen)
+{
+	/* Find the first space to separate function name from args */
+	const char *space = NULL;
+	for (size_t i = 0; i < nameLen; i++) {
+		if (name[i] == ' ' || name[i] == '\t') {
+			space = &name[i];
+			break;
+		}
+	}
+	if (space == NULL)
+		return NULL;
+
+	size_t funcLen = (size_t)(space - name);
+	const char *rawArgs = space + 1;
+	size_t rawArgsLen = nameLen - funcLen - 1;
+
+	/* Split raw args by commas */
+	const char *argStarts[10];
