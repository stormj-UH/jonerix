+/* ---- function implementations ---- */
+
+static char *
+gnufunc_strip(const char *arg)
+{
+	Buffer buf;
+	Buf_Init(&buf);
+	bool inSpace = true;
+	for (const char *p = arg; *p != '\0'; p++) {
+		if (*p == ' ' || *p == '\t' || *p == '\n') {
+			if (!inSpace && p[1] != '\0') {
+				/* peek ahead: only add space if more non-ws follows */
+				const char *q = p + 1;
+				while (*q == ' ' || *q == '\t' || *q == '\n') q++;
+				if (*q != '\0')
+					Buf_AddByte(&buf, ' ');
+			}
+			inSpace = true;
+		} else {
+			Buf_AddByte(&buf, *p);
+			inSpace = false;
+		}
+	}
+	return Buf_DoneData(&buf);
+}
+
+static char *
+gnufunc_sort(const char *arg)
+{
+	SubstringWords words = Substring_Words(arg, false);
+	if (words.len == 0) {
+		SubstringWords_Free(words);
+		return bmake_strdup("");
+	}
+
+	/* simple insertion sort + dedup */
+	/* first, convert to C strings for qsort */
+	char **strs = bmake_malloc(words.len * sizeof(char *));
+	for (size_t i = 0; i < words.len; i++)
+		strs[i] = bmake_strldup(words.words[i].start,
+			Substring_Length(words.words[i]));
+	SubstringWords_Free(words);
+
+	/* sort */
+	for (size_t i = 1; i < words.len; i++) {
+		char *key = strs[i];
+		size_t j = i;
+		while (j > 0 && strcmp(strs[j - 1], key) > 0) {
+			strs[j] = strs[j - 1];
+			j--;
+		}
+		strs[j] = key;
+	}
+
+	/* join + dedup */
+	Buffer buf;
+	Buf_Init(&buf);
+	for (size_t i = 0; i < words.len; i++) {
+		if (i > 0 && strcmp(strs[i], strs[i - 1]) == 0) {
+			free(strs[i]);
+			continue;
+		}
+		if (Buf_EndsWith(&buf, ' ') == false && buf.len > 0)
+			Buf_AddByte(&buf, ' ');
+		Buf_AddStr(&buf, strs[i]);
+		free(strs[i]);
+	}
+	free(strs);
+	return Buf_DoneData(&buf);
+}
