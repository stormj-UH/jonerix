+/* GNU make function compatibility (added for jonerix).
+ *
+ * Implements: sort, filter, filter-out, patsubst, subst,
+ * addprefix, addsuffix, notdir, dir, basename, suffix,
+ * wildcard, shell, strip, findstring, abspath, realpath,
+ * words, word, firstword, lastword, wordlist,
+ * if, or, and, error, warning, info.
+ *
+ * Detected when a variable name contains a space and the
+ * first word matches a known function name.
+ */
+
+static int
+gnufunc_split_args(const char *s, size_t slen,
+		   const char **starts, size_t *lens, int max)
+{
+	int n = 0, depth = 0;
+	const char *end = s + slen;
+	const char *seg = s;
+
+	for (const char *p = s; p < end && n < max - 1; p++) {
+		if (*p == '(' || *p == '{')
+			depth++;
+		else if ((*p == ')' || *p == '}') && depth > 0)
+			depth--;
+		else if (*p == ',' && depth == 0) {
+			starts[n] = seg;
+			lens[n] = (size_t)(p - seg);
+			n++;
+			seg = p + 1;
+		}
+	}
+	starts[n] = seg;
+	lens[n] = (size_t)(end - seg);
+	n++;
+	return n;
+}
+
+/* Make a NUL-terminated copy, stripping leading+trailing whitespace. */
+static char *
+gnufunc_strip_dup(const char *s, size_t len)
+{
+	while (len > 0 && (*s == ' ' || *s == '\t')) { s++; len--; }
+	while (len > 0 && (s[len - 1] == ' ' || s[len - 1] == '\t')) len--;
+	return bmake_strldup(s, len);
+}
+
+/* Simple % pattern match.  Returns pointer to the stem start if
+ * word matches pattern (which may contain one '%'), else NULL.
+ * Sets *stemLen to the stem length. */
+static const char *
+gnufunc_pat_match(const char *word, size_t wlen,
+		  const char *pat, size_t plen, size_t *stemLen)
+{
+	const char *pct = memchr(pat, '%', plen);
+	if (pct == NULL) {
+		/* literal match */
+		if (wlen == plen && memcmp(word, pat, plen) == 0) {
+			*stemLen = 0;
+			return word;
+		}
+		return NULL;
+	}
+	size_t prefixLen = (size_t)(pct - pat);
+	size_t suffixLen = plen - prefixLen - 1;
+	if (wlen < prefixLen + suffixLen)
+		return NULL;
+	if (memcmp(word, pat, prefixLen) != 0)
+		return NULL;
+	if (memcmp(word + wlen - suffixLen, pct + 1, suffixLen) != 0)
+		return NULL;
+	*stemLen = wlen - prefixLen - suffixLen;
+	return word + prefixLen;
+}
+
+/* Apply % substitution: replace % in repl with stem. */
+static char *
+gnufunc_pat_subst(const char *repl, size_t rlen,
+		  const char *stem, size_t stemLen)
+{
+	const char *pct = memchr(repl, '%', rlen);
+	if (pct == NULL)
+		return bmake_strldup(repl, rlen);
+
+	size_t prefLen = (size_t)(pct - repl);
+	size_t sufLen = rlen - prefLen - 1;
+	size_t outLen = prefLen + stemLen + sufLen;
+	char *out = bmake_malloc(outLen + 1);
+	memcpy(out, repl, prefLen);
+	memcpy(out + prefLen, stem, stemLen);
+	memcpy(out + prefLen + stemLen, pct + 1, sufLen);
+	out[outLen] = '\0';
+	return out;
+}
