+/* $(or arg1[,arg2,...]) — return first non-empty */
+static char *
+gnufunc_or(const char **args, size_t *lens, int nargs)
+{
+	for (int i = 0; i < nargs; i++) {
+		char *a = gnufunc_strip_dup(args[i], lens[i]);
+		if (a[0] != '\0')
+			return a;
+		free(a);
+	}
+	return bmake_strdup("");
+}
