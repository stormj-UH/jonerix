+/* $(and arg1[,arg2,...]) — return last if all non-empty, else empty */
+static char *
+gnufunc_and(const char **args, size_t *lens, int nargs)
+{
+	char *last = NULL;
+	for (int i = 0; i < nargs; i++) {
+		free(last);
+		last = gnufunc_strip_dup(args[i], lens[i]);
+		if (last[0] == '\0')
+			return last;
+	}
+	return last ? last : bmake_strdup("");
+}
