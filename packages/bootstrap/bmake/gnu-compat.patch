 }
 
+/* $(patsubst pattern,replacement,text) */
+static char *
+gnufunc_patsubst(const char *pattern, const char *repl, const char *text)
+{
+	size_t patLen = strlen(pattern);
+	size_t replLen = strlen(repl);
+	SubstringWords words = Substring_Words(text, false);
+	Buffer buf;
+	Buf_Init(&buf);
+
+	for (size_t i = 0; i < words.len; i++) {
+		if (buf.len > 0) Buf_AddByte(&buf, ' ');
+		char *w = bmake_strldup(words.words[i].start,
+			Substring_Length(words.words[i]));
+		size_t wLen = strlen(w);
+		size_t stemLen;
+		const char *stem = gnufunc_pat_match(w, wLen, pattern, patLen, &stemLen);
+		if (stem != NULL) {
+			char *sub = gnufunc_pat_subst(repl, replLen, stem, stemLen);
+			Buf_AddStr(&buf, sub);
+			free(sub);
+		} else {
+			Buf_AddStr(&buf, w);
+		}
+		free(w);
+	}
+	SubstringWords_Free(words);
+	return Buf_DoneData(&buf);
+}
+
+/* $(subst from,to,text) — literal substitution */
+static char *
+gnufunc_subst(const char *from, const char *to, const char *text)
+{
+	size_t fromLen = strlen(from);
+	size_t toLen = strlen(to);
+
+	if (fromLen == 0)
+		return bmake_strdup(text);
+
+	Buffer buf;
+	Buf_Init(&buf);
+	const char *p = text;
+	while (*p != '\0') {
+		if (strncmp(p, from, fromLen) == 0) {
+			Buf_AddBytes(&buf, to, toLen);
+			p += fromLen;
+		} else {
+			Buf_AddByte(&buf, *p);
+			p++;
+		}
+	}
+	return Buf_DoneData(&buf);
+}
