#!/bin/openrc-run
# tty1-console — respawn a root shell on /dev/tty1 (HDMI console).
#
# Replaces agetty/getty for jonerix: neither util-linux's agetty nor
# toybox's getty applet set ships on jonerix (permissive-license-only;
# util-linux is GPL). This service loops an interactive root shell on
# tty1 so HDMI-attached consoles get a usable prompt without a proper
# getty. Auto-login (no password); suitable for local-only boxes like
# kiosks, dev Pis, embedded hosts.

name="tty1-console"
description="Auto-login root shell on /dev/tty1 (HDMI console)"

command="/bin/mksh"
command_args='-c "while :; do /bin/sh -l </dev/tty1 >/dev/tty1 2>&1; sleep 1; done"'
command_background="yes"
pidfile="/run/tty1-console.pid"

depend() {
    need localmount
    after devfs sysfs
}

start_pre() {
    # Make sure tty1 exists. On devtmpfs kernels it will; stub creation
    # is a no-op safeguard for minimal environments.
    [ -c /dev/tty1 ] || mknod /dev/tty1 c 4 1 2>/dev/null || true
}
