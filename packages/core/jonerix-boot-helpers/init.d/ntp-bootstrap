#!/bin/openrc-run
# ntp-bootstrap — set system clock via HTTP Date header before ntpd.
#
# Why: openntpd refuses to jump the clock by decades at cold boot
# on RTC-less hardware (Raspberry Pi 5 etc.) — its default max-
# adjustment threshold is much smaller than the 1970→today gap.
# The old `ntpd -s` force-set mode was removed upstream. Meanwhile
# tailscaled, dropbear, and any TLS-using daemon fail because certs
# are "not yet valid" when clock is 1970.
#
# This service runs /bin/ntp-set-http (HTTP Date header, no TLS)
# BEFORE ntpd and tailscaled, getting the clock close enough that
# those daemons' TLS works. ntpd then takes over for proper sync.
#
# Idempotent: running with an already-correct clock is a no-op
# (HTTP Date has 1-sec resolution, worst case ntpd smooths the tiny
# offset).
#
# Exits 0 even if HTTP probe fails — failing boot here is worse
# than starting with a wrong clock (which ntpd will eventually
# correct via its slew behavior).

description="Bootstrap system clock via HTTP Date header (for RTC-less hosts)"

depend() {
    need net
    before ntpd tailscaled
}

start() {
    ebegin "Bootstrapping clock via HTTP Date header"
    /bin/ntp-set-http || true
    eend 0
}
