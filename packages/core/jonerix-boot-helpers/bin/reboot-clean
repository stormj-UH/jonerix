#!/bin/mksh
# /bin/reboot-clean — graceful reboot for jonerix.
#
# Plain `reboot` calls reboot(RB_AUTOBOOT) and hard-resets the kernel
# with no flush/unmount. On SD card that means ext4 corruption on the
# next mount (we saw this on jonerix-tormenta 2026-04-16: inode 287372
# had extent magic 204f instead of f30a). `openrc shutdown` stops
# services but does not always give them time to release writable fds
# on / before mount-ro runs, leaving EBUSY and a dirty rootfs.
#
# This wrapper:
#   1. Gracefully stops services that hold writable fds on ext4 /
#      (tailscaled, syslogd, ntp-set-cron, dhcpcd, sshd, …) in reverse
#      start order. Uses rc-service stop + wait loop.
#   2. SIGKILLs anything still holding a writable fd on /var, /etc,
#      /home, /root (except PID 1 and self).
#   3. Runs /bin/openrc shutdown for the canonical shutdown runlevel
#      (unmounts /boot /tmp, mount-ro on /).
#   4. sync × 3.
#   5. /bin/reboot — at this point / is clean and ro.

set +e
echo "== jonerix clean reboot =="
date

# 1. Stop writable-fd services in reverse start order
for svc in tty1-console tailscaled ntp-set-cron snooze syslog-forward syslogd sshd dhcpcd; do
    if rc-service --quiet "$svc" status 2>/dev/null; then
        echo "-> stopping $svc"
        rc-service "$svc" stop 2>&1 | tail -2
    fi
done

# 2. Wait up to 10s for services to actually exit
i=0
while [ $i -lt 10 ]; do
    pending=$(ps 2>/dev/null | grep -cE "[t]ailscaled|[s]yslogd|[d]hcpcd")
    [ "$pending" = "0" ] && break
    sleep 1
    i=$((i + 1))
done

# 3. SIGKILL anything still holding ext4 / writable fds
self=$$
for pid in $(ls /proc 2>/dev/null | grep -E "^[0-9]+$"); do
    [ "$pid" = "1" ] && continue
    [ "$pid" = "$self" ] && continue
    for fd in /proc/$pid/fd/*; do
        tgt=$(readlink "$fd" 2>/dev/null)
        [ -z "$tgt" ] && continue
        case "$tgt" in
            /var/*|/etc/*|/home/*|/root/*)
                echo "-> SIGKILL pid=$pid (fd->$tgt)"
                kill -9 "$pid" 2>/dev/null
                break
                ;;
        esac
    done
done
sleep 1

# 4. Canonical OpenRC shutdown runlevel
echo "-> /bin/openrc shutdown"
/bin/openrc shutdown 2>&1 | tail -10

# 5. Final flush
echo "-> sync"
sync; sync; sync

# 6. Actually reboot
echo "-> /bin/reboot ($(date))"
exec /bin/reboot
