#!/bin/openrc-run
# shadow-login — supervise-daemon-respawned shadow-getty on /dev/tty1.
#
# Prior versions tried a shell wrapper (mksh + stty + setsid) between
# OpenRC and /bin/login. That path had a handful of failure modes on
# jonerix specifically — toybox stty refuses individual knobs on some
# kernel virtual-console states, setsid without -c can't claim a ctty,
# and a pipe-stdin from supervise-daemon made /bin/login see EOF and
# exit immediately, causing a once-per-second respawn loop.
#
# shadow-getty (a ~100-line C helper shipped by this package) does the
# whole getty dance directly: setsid → open /dev/ttyN → TIOCSCTTY →
# dup2 0/1/2 → tcsetattr → execl /bin/login -p. No shell layer means
# no ambiguity; supervise-daemon just respawns the single C process
# when login(1) returns.
#
# Part of shadow (BSD-3-Clause jonerix core jpkg).

name="shadow-login"
description="shadow-utils login(1) on /dev/tty1 via shadow-getty"

supervisor="supervise-daemon"

command="/bin/shadow-getty"
command_args="/dev/tty1"

# Respawn cadence — 1s delay, no retry cap. If shadow-getty or login
# were misbehaving (e.g. the wrapper days), a tight loop would wedge
# the tty; that can't happen now that the helper doesn't return
# until login itself returns.
respawn_delay=1
respawn_max=0

# supervise-daemon captures child stderr by default; aim both at the
# same log so one glance shows everything.
output_log="/var/log/shadow-login.log"
error_log="/var/log/shadow-login.log"

depend() {
    need localmount
    after devfs
    keyword -jail -prefix -vserver
}
