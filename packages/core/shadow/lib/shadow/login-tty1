#!/bin/mksh
# /lib/shadow/login-tty1 — single-shot tty1 login wrapper.
#
# Invoked by /etc/init.d/shadow-login under supervise-daemon. Sets up
# the controlling terminal + line discipline + TERM, then exec()s
# /bin/login. When login exits (logout, auth failure, internal 60s
# timeout, etc.) this script exits too and supervise-daemon spawns a
# fresh copy.
#
# Exec'ing rather than looping is deliberate — see /etc/init.d/shadow-
# login for the rationale. One supervised process at a time.

set -u

# Become a session leader detached from any controlling tty inherited
# from the OpenRC service runner; then claim /dev/tty1 as our own.
# `setsid -c` is the busybox/toybox-friendly form of "fork into a
# fresh session and make argv[0] the controlling tty". jonerix's mksh
# can't `setsid` itself, so we re-exec under setsid if we weren't
# already started by it.
if [ -z "${SHADOW_LOGIN_SETSID:-}" ]; then
    SHADOW_LOGIN_SETSID=1 exec setsid -c "$0" "$@"
fi

# Redirect every standard fd to tty1. login(1) inherits these and
# treats fd 0 as its terminal.
exec </dev/tty1 >/dev/tty1 2>&1

# Reset to sane line discipline. A previous getty/login that crashed
# can leave the tty in raw or non-blocking mode; `stty sane` clears
# that. Then reaffirm the erase key — Linux VC sends DEL (0x7F) on
# Backspace, and stty's "sane" preset sometimes maps erase to ^H,
# which produces a literal `~` echo when the user hits Backspace
# under zsh's default keymap. Pin it to ^? so Backspace works.
stty sane
stty erase ^?

# TERM=linux: tty1 IS a Linux virtual console. Without this, login(1)
# clears the env (default) so the user's shell ends up at TERM=dumb
# — zsh skips ANSI colour and arrow keys send literal escape codes.
# `login -p` preserves what we set here.
export TERM=linux

# And go. login(1) doesn't return on success; it exec()s the user's
# shell. On failure / logout / timeout it exits, this script exits
# with login's status, supervise-daemon restarts us.
exec /bin/login -p
