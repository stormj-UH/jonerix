#
# toybox configuration for jonerix
# Generated for toybox 0.8.11
#
# This config enables the coreutils, file manipulation, text processing,
# process management, and system administration applets needed for a
# minimal but functional Linux server.
#

#
# General settings
#
CONFIG_TOYBOX=y
CONFIG_TOYBOX_SUID=y
CONFIG_TOYBOX_LSM_NONE=y
# CONFIG_TOYBOX_SELINUX is not set
# CONFIG_TOYBOX_SMACK is not set
CONFIG_TOYBOX_SHADOW=y
CONFIG_TOYBOX_UID_SYS=100
