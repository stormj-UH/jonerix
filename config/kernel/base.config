#
# config/kernel/base.config — mandatory floor for any jonerix kernel.
#
# Merge with `scripts/kconfig/merge_config.sh` BEFORE the arch and
# profile fragments.  Every option here is required — disabling
# anything in this file breaks one or more shipped jonerix packages
# (musl, OpenRC, brash, docker, etc.).
#

# ── General setup ──────────────────────────────────────────────────────
CONFIG_LOCALVERSION="-jonerix"
# CONFIG_LOCALVERSION_AUTO is not set
CONFIG_DEFAULT_HOSTNAME="jonerix"
CONFIG_KERNEL_GZIP=y                    # OK on all platforms; XZ is also fine
CONFIG_AUDIT=y
CONFIG_NO_HZ_IDLE=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_CPU_ISOLATION=y

# ── POSIX IPC — used by OpenRC's depcheck and many daemons ──────────────
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_CROSS_MEMORY_ATTACH=y

# ── Modern syscall API surface ──────────────────────────────────────────
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_AIO=y
CONFIG_IO_URING=y
CONFIG_MEMBARRIER=y
CONFIG_USERFAULTFD=y                    # docker, criu, jvm gc
CONFIG_PIDFD_SYSCALL=y                  # systemd-style PID stability for runc
CONFIG_INOTIFY_USER=y                   # build watchers, vite/webpack
CONFIG_FANOTIFY=y
CONFIG_FANOTIFY_ACCESS_PERMISSIONS=y
CONFIG_FHANDLE=y

# ── Namespaces (everywhere — docker/podman/buildah/firejail all need them) ─
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_TIME_NS=y

# ── Cgroups v2 (unified hierarchy) ─────────────────────────────────────
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_HUGETLB=y
CONFIG_CPUSETS=y
CONFIG_PROC_PID_CPUSET=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_BPF=y
CONFIG_CGROUP_MISC=y

# ── Modules ────────────────────────────────────────────────────────────
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=y            # for the brcmfmac unload-after-fwerr path
CONFIG_MODVERSIONS=y
CONFIG_KALLSYMS=y                       # required for live BPF / perf annotation
CONFIG_KALLSYMS_ALL=y

# ── Memory management ─────────────────────────────────────────────────
CONFIG_SLUB=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y   # apps opt-in; never automatic
CONFIG_KSM=y
CONFIG_ZSMALLOC=y
CONFIG_ZRAM=y                           # zram swap on low-RAM machines
CONFIG_ZSWAP=y
CONFIG_COMPACTION=y

# ── Block layer ────────────────────────────────────────────────────────
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_NBD=m
CONFIG_BLK_DEV_DM=y                     # device-mapper for cryptsetup/lvm
CONFIG_DM_CRYPT=m
CONFIG_DM_THIN_PROVISIONING=m

# ── Filesystems ────────────────────────────────────────────────────────
CONFIG_EXT4_FS=y                        # default rootfs format
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_VFAT_FS=y                        # /boot on Pi 5
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_HUGETLBFS=y
CONFIG_OVERLAY_FS=y                     # docker, podman, container bootstrap
CONFIG_OVERLAY_FS_REDIRECT_DIR=y
CONFIG_FUSE_FS=y                        # rclone mount, sshfs, ntfs-3g
CONFIG_PROC_FS=y
CONFIG_PROC_KCORE=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y                 # mounted by the kernel pre-init
CONFIG_NLS_UTF8=y
CONFIG_NLS_CODEPAGE_437=y               # FAT32 on /boot
CONFIG_NLS_ISO8859_1=y

# ── Networking core ────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_PACKET=y                         # AF_PACKET for tcpdump, dhcpcd
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_NETLABEL=y
CONFIG_NETLINK_DIAG=y                   # ss / tailscaled

# Congestion control — make BBR available; default to it.
CONFIG_TCP_CONG_BBR=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_TCP_MD5SIG=y                     # BGP and a few backbone services need it

# Queueing — make fq_codel + cake available.
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_CAKE=m

# UDP segmentation offload (GSO) — needed by tailscale / wireguard
# performance.
CONFIG_NET_UDP_TUNNEL=m

# ── BPF — modern observability and security baseline ─────────────────
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_HAVE_EBPF_JIT=y
CONFIG_BPF_EVENTS=y
CONFIG_KPROBE_EVENTS=y
CONFIG_UPROBE_EVENTS=y
CONFIG_TRACING=y

# ── Tracing / perf — kept on so bpftrace, perf, and trace-cmd work ────
CONFIG_PERF_EVENTS=y
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_KPROBES=y
CONFIG_UPROBES=y

# ── Crypto — what musl + openssl ask for ──────────────────────────────
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_GCM=y
CONFIG_CRYPTO_CCM=y
CONFIG_CRYPTO_USER_API_AEAD=m
CONFIG_CRYPTO_USER_API_HASH=m
CONFIG_CRYPTO_USER_API_SKCIPHER=m
CONFIG_CRYPTO_USER_API_RNG=m

# Hardware-accelerated crypto where the arch fragment will enable
# the chip-specific implementations.

# ── Security baseline ──────────────────────────────────────────────────
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_INIT_STACK_ALL_ZERO=y            # CWE-457 mitigation, ~1% perf hit
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_VMAP_STACK=y
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_STRICT_MODULE_RWX=y
CONFIG_DEBUG_WX=y                       # warn if any kernel page is W+X

# ── Firmware loading ───────────────────────────────────────────────────
CONFIG_FW_LOADER=y
CONFIG_EXTRA_FIRMWARE=""
CONFIG_FW_LOADER_USER_HELPER=n          # legacy /sbin/hotplug, off

# ── Random number subsystem ────────────────────────────────────────────
CONFIG_RANDOM_TRUST_BOOTLOADER=y        # accept early entropy
CONFIG_RANDOM_TRUST_CPU=y               # RDRAND on x86, RNDR on aarch64

# ── Device drivers — the bare bones every kernel needs ────────────────
CONFIG_TTY=y
CONFIG_UNIX98_PTYS=y
CONFIG_DEVPTS_MULTIPLE_INSTANCES=y      # per-container /dev/pts (docker)
CONFIG_HW_RANDOM=y

# ── /dev/null /dev/zero etc. ───────────────────────────────────────────
CONFIG_DEVMEM=n                         # off — modern systems use sysfs
CONFIG_DEVKMEM=n
CONFIG_DEVPORT=n
