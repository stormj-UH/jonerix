#
# config/kernel/profile/builder.config — build host / dev workstation / CI runner.
#
# Adds container runtime support, nested virt (KVM), full netfilter
# for docker/podman bridge networking, observability (BPF + perf +
# tracing), and the bulky filesystem set that build tools assume.
#

# ── Filesystems builders need ─────────────────────────────────────────
CONFIG_BTRFS_FS=m                       # docker btrfs backend, snapper
CONFIG_BTRFS_FS_POSIX_ACL=y
CONFIG_F2FS_FS=m                        # some Android/Asahi devs use it
CONFIG_SQUASHFS=m                       # container layer reads
CONFIG_SQUASHFS_XATTR=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_NFS_FS=m
CONFIG_NFS_V4=y
CONFIG_NFS_V4_1=y
CONFIG_NFSD=m
CONFIG_CIFS=m
CONFIG_AUTOFS_FS=m
CONFIG_EXT4_FS_QUOTA=y
CONFIG_QUOTA=y
CONFIG_QUOTACTL=y

# ── Block-layer features ──────────────────────────────────────────────
CONFIG_BLK_DEV_DM=y
CONFIG_DM_THIN_PROVISIONING=m
CONFIG_DM_CRYPT=m
CONFIG_DM_SNAPSHOT=m
CONFIG_DM_MIRROR=m
CONFIG_DM_RAID=m

# ── Container networking ──────────────────────────────────────────────
CONFIG_VETH=m
CONFIG_BRIDGE=m
CONFIG_BRIDGE_NETFILTER=m
CONFIG_BRIDGE_VLAN_FILTERING=y
CONFIG_VLAN_8021Q=m
CONFIG_TUN=m
CONFIG_MACVLAN=m
CONFIG_MACVTAP=m
CONFIG_IPVLAN=m
CONFIG_IPVTAP=m
CONFIG_NET_FOU=m
CONFIG_GENEVE=m
CONFIG_VXLAN=m

# ── Netfilter — full IPv4 + IPv6 + bridge ────────────────────────────
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=m
CONFIG_NF_CONNTRACK_FTP=m
CONFIG_NF_CONNTRACK_SIP=m
CONFIG_NF_CONNTRACK_TFTP=m
CONFIG_NF_CONNTRACK_IRC=m
CONFIG_NF_CONNTRACK_NETBIOS_NS=m
CONFIG_NF_CONNTRACK_PROCFS=y            # ss -t /proc/net/nf_conntrack
CONFIG_NF_CT_NETLINK=m
CONFIG_NF_NAT=m
CONFIG_NF_NAT_MASQUERADE=y
CONFIG_NF_NAT_REDIRECT=y                # docker -p NN:NN

CONFIG_NF_TABLES=m
CONFIG_NF_TABLES_INET=m
CONFIG_NF_TABLES_IPV4=m
CONFIG_NF_TABLES_IPV6=m
CONFIG_NF_TABLES_BRIDGE=m
CONFIG_NF_TABLES_NETDEV=m
CONFIG_NFT_NAT=m
CONFIG_NFT_MASQ=m
CONFIG_NFT_REDIR=m
CONFIG_NFT_REJECT=m
CONFIG_NFT_LOG=m
CONFIG_NFT_LIMIT=m
CONFIG_NFT_CT=m
CONFIG_NFT_HASH=m
CONFIG_NFT_QUOTA=m

# Legacy iptables/ip6tables (docker libnetwork shells out to these).
CONFIG_IP_NF_IPTABLES=m
CONFIG_IP_NF_FILTER=m
CONFIG_IP_NF_NAT=m
CONFIG_IP_NF_TARGET_MASQUERADE=m
CONFIG_IP6_NF_IPTABLES=m
CONFIG_IP6_NF_FILTER=m
CONFIG_IP6_NF_NAT=m
CONFIG_IP6_NF_TARGET_MASQUERADE=m

# ── KVM host — let the builder run VMs (qemu, microvm, firecracker) ──
# KVM_INTEL/KVM_AMD come from the arch fragment.
CONFIG_VIRTUALIZATION=y
CONFIG_VHOST=m
CONFIG_VHOST_NET=m
CONFIG_VHOST_VSOCK=m

# ── Observability — bpftrace, perf, eBPF tools ───────────────────────
CONFIG_PERF_EVENTS=y
CONFIG_HAVE_PERF_EVENTS=y
CONFIG_FTRACE=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_GRAPH_TRACER=y
CONFIG_STACK_TRACER=y
CONFIG_SCHED_TRACER=y
CONFIG_FTRACE_SYSCALLS=y
CONFIG_BLK_DEV_IO_TRACE=y               # blktrace, biolatency
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_UPROBES=y
CONFIG_UPROBE_EVENTS=y
CONFIG_BPF_KPROBE_OVERRIDE=y

# Allow non-root users to use BPF features (perf-record, bpftool).
CONFIG_BPF_UNPRIV_DEFAULT_OFF=n         # leave unprivileged BPF available

# ── Profiling friends ────────────────────────────────────────────────
CONFIG_NET_NS=y
CONFIG_HUGETLBFS=y
CONFIG_TRANSPARENT_HUGEPAGE=y

# ── Memory features for big builds ───────────────────────────────────
CONFIG_USERFAULTFD=y
CONFIG_MEMORY_HOTPLUG=y                 # for VMs you grow at runtime
CONFIG_MEMORY_HOTPLUG_DEFAULT_ONLINE=y

# ── Scheduler — CFS bandwidth control + ICache + autogroup ───────────
CONFIG_HZ_1000=y
# CONFIG_HZ_100 is not set
CONFIG_HZ=1000                          # finer scheduling for many short tasks
CONFIG_PREEMPT_DYNAMIC=y                # runtime preempt toggle
CONFIG_PREEMPT_VOLUNTARY=y
CONFIG_SCHED_AUTOGROUP=y

# ── Watchdog (catch hung builds rather than freezing the box) ────────
CONFIG_SOFTLOCKUP_DETECTOR=y
CONFIG_HARDLOCKUP_DETECTOR=y
CONFIG_DETECT_HUNG_TASK=y
CONFIG_BOOTPARAM_HUNG_TASK_PANIC=n      # warn, don't panic
