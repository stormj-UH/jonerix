#
# config/kernel/profile/router.config — network appliance.
#
# Pairs with the router profile's /etc/sysctl.d/router.conf (which
# turns on forwarding) and the nftables ruleset.  This fragment
# enables the kernel-side networking surface a NAT router /
# Wi-Fi AP / VPN gateway actually uses.  Disables build-host and
# desktop bloat to keep the image small.
#

# ── Advanced routing ──────────────────────────────────────────────────
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y             # `ip rule` with multiple tables
CONFIG_IP_ROUTE_MULTIPATH=y             # ECMP
CONFIG_IP_ROUTE_VERBOSE=y
CONFIG_IPV6_MULTIPLE_TABLES=y
CONFIG_IPV6_SUBTREES=y
CONFIG_IPV6_OPTIMISTIC_DAD=y
CONFIG_IPV6_PIMSM_V2=m

# ── Multicast routing (PIM-SM, M-Bone, IGMP proxy) ───────────────────
CONFIG_IP_MROUTE=y
CONFIG_IP_MROUTE_MULTIPLE_TABLES=y
CONFIG_IP_PIMSM_V1=y
CONFIG_IP_PIMSM_V2=y
CONFIG_IPV6_MROUTE=y
CONFIG_IPV6_MROUTE_MULTIPLE_TABLES=y

# ── Bonding / VLAN / Bridge ───────────────────────────────────────────
CONFIG_BONDING=m
CONFIG_DUMMY=m
CONFIG_VLAN_8021Q=y
CONFIG_VLAN_8021Q_GVRP=y
CONFIG_VLAN_8021Q_MVRP=y
CONFIG_BRIDGE=y
CONFIG_BRIDGE_VLAN_FILTERING=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_BRIDGE_IGMP_SNOOPING=y

# ── Tunneling ─────────────────────────────────────────────────────────
CONFIG_TUN=y
CONFIG_NET_IPGRE_DEMUX=m
CONFIG_NET_IPGRE=m
CONFIG_NET_IPGRE_BROADCAST=y
CONFIG_NET_IPIP=m
CONFIG_IPV6_TUNNEL=m
CONFIG_IPV6_GRE=m
CONFIG_IP_TUNNEL=m
CONFIG_IP_VTI=m
CONFIG_IPV6_VTI=m
CONFIG_GENEVE=m
CONFIG_VXLAN=m
CONFIG_GTP=m
CONFIG_PPP=m
CONFIG_PPP_BSDCOMP=m
CONFIG_PPP_DEFLATE=m
CONFIG_PPP_FILTER=y
CONFIG_PPP_MPPE=m
CONFIG_PPP_MULTILINK=y
CONFIG_PPPOE=m
CONFIG_PPPOL2TP=m
CONFIG_L2TP=m
CONFIG_L2TP_V3=y

# ── WireGuard — modern VPN of choice ──────────────────────────────────
CONFIG_WIREGUARD=m

# ── MPTCP — multi-path TCP (matters on dual-WAN setups) ──────────────
CONFIG_MPTCP=y
CONFIG_MPTCP_IPV6=y

# ── Traffic control / shaping ────────────────────────────────────────
CONFIG_NET_SCHED=y
CONFIG_NET_SCH_HTB=m                    # classic hierarchical bandwidth
CONFIG_NET_SCH_CAKE=m                   # the modern default for home routers
CONFIG_NET_SCH_FQ_CODEL=m
CONFIG_NET_SCH_FQ=m
CONFIG_NET_SCH_SFQ=m
CONFIG_NET_SCH_PRIO=m
CONFIG_NET_SCH_HFSC=m
CONFIG_NET_SCH_NETEM=m                  # network emulation for testing
CONFIG_NET_SCH_TBF=m
CONFIG_NET_SCH_INGRESS=m
CONFIG_NET_SCH_DSMARK=m

# Classifiers + actions for the above.
CONFIG_NET_CLS_BASIC=m
CONFIG_NET_CLS_TCINDEX=m
CONFIG_NET_CLS_ROUTE4=m
CONFIG_NET_CLS_FW=m
CONFIG_NET_CLS_U32=m
CONFIG_NET_CLS_FLOW=m
CONFIG_NET_CLS_CGROUP=m
CONFIG_NET_CLS_BPF=m
CONFIG_NET_CLS_FLOWER=m
CONFIG_NET_CLS_MATCHALL=m
CONFIG_NET_ACT_POLICE=m
CONFIG_NET_ACT_GACT=m
CONFIG_NET_ACT_MIRRED=m
CONFIG_NET_ACT_SAMPLE=m
CONFIG_NET_ACT_NAT=m
CONFIG_NET_ACT_PEDIT=m
CONFIG_NET_ACT_SKBEDIT=m
CONFIG_NET_ACT_BPF=m

# ── Netfilter — the full firewall surface ────────────────────────────
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NETFILTER_NETLINK=m
CONFIG_NETFILTER_NETLINK_LOG=m
CONFIG_NETFILTER_NETLINK_QUEUE=m
CONFIG_NF_CONNTRACK=m
CONFIG_NF_CT_NETLINK=m
CONFIG_NF_CONNTRACK_FTP=m
CONFIG_NF_CONNTRACK_IRC=m
CONFIG_NF_CONNTRACK_TFTP=m
CONFIG_NF_CONNTRACK_SIP=m
CONFIG_NF_CONNTRACK_AMANDA=m
CONFIG_NF_CONNTRACK_SANE=m
CONFIG_NF_CONNTRACK_H323=m
CONFIG_NF_CONNTRACK_NETBIOS_NS=m
CONFIG_NF_CONNTRACK_PROCFS=y
CONFIG_NF_NAT=m
CONFIG_NF_NAT_FTP=m
CONFIG_NF_NAT_IRC=m
CONFIG_NF_NAT_SIP=m
CONFIG_NF_NAT_TFTP=m
CONFIG_NF_NAT_MASQUERADE=y
CONFIG_NF_NAT_REDIRECT=y

# nftables full set.
CONFIG_NF_TABLES=m
CONFIG_NF_TABLES_INET=m
CONFIG_NF_TABLES_IPV4=m
CONFIG_NF_TABLES_IPV6=m
CONFIG_NF_TABLES_BRIDGE=m
CONFIG_NF_TABLES_NETDEV=m
CONFIG_NF_TABLES_ARP=m
CONFIG_NFT_CT=m
CONFIG_NFT_CONNLIMIT=m
CONFIG_NFT_LOG=m
CONFIG_NFT_LIMIT=m
CONFIG_NFT_QUOTA=m
CONFIG_NFT_REJECT=m
CONFIG_NFT_HASH=m
CONFIG_NFT_FIB=m
CONFIG_NFT_FIB_INET=m
CONFIG_NFT_FIB_IPV4=m
CONFIG_NFT_FIB_IPV6=m
CONFIG_NFT_NAT=m
CONFIG_NFT_MASQ=m
CONFIG_NFT_REDIR=m
CONFIG_NFT_SOCKET=m
CONFIG_NFT_TPROXY=m
CONFIG_NFT_SYNPROXY=m
CONFIG_NFT_FLOW_OFFLOAD=m              # h/w offload via switchdev (where available)
CONFIG_NFT_TUNNEL=m
CONFIG_NFT_OBJREF=m
CONFIG_NFT_SET_HASH=m
CONFIG_NFT_SET_RBTREE=m
CONFIG_NFT_SET_BITMAP=m
CONFIG_NFT_DUP_NETDEV=m
CONFIG_NFT_FWD_NETDEV=m

# ipset (some user-space tools — e.g. firewalld, openbsd-style rules
# — still write ipsets).
CONFIG_IP_SET=m
CONFIG_IP_SET_BITMAP_IP=m
CONFIG_IP_SET_BITMAP_IPMAC=m
CONFIG_IP_SET_BITMAP_PORT=m
CONFIG_IP_SET_HASH_IP=m
CONFIG_IP_SET_HASH_IPPORT=m
CONFIG_IP_SET_HASH_NET=m
CONFIG_IP_SET_HASH_NETPORT=m
CONFIG_IP_SET_LIST_SET=m

# Legacy iptables (lots of router-script wisdom is written in
# iptables; nft is the modern path but many recipes still use
# iptables-{nft,legacy}).
CONFIG_IP_NF_IPTABLES=m
CONFIG_IP_NF_FILTER=m
CONFIG_IP_NF_NAT=m
CONFIG_IP_NF_MANGLE=m
CONFIG_IP_NF_RAW=m
CONFIG_IP_NF_SECURITY=m
CONFIG_IP_NF_TARGET_MASQUERADE=m
CONFIG_IP_NF_TARGET_REDIRECT=m
CONFIG_IP6_NF_IPTABLES=m
CONFIG_IP6_NF_FILTER=m
CONFIG_IP6_NF_MANGLE=m
CONFIG_IP6_NF_NAT=m

# ── 802.11 + hostapd path (Pi 5 onboard Wi-Fi → AP mode) ─────────────
CONFIG_CFG80211=m
CONFIG_MAC80211=m
CONFIG_MAC80211_MESH=y
CONFIG_RFKILL=y

# ── No build-host bloat (keep image small) ────────────────────────────
# CONFIG_BTRFS_FS is not set
# CONFIG_F2FS_FS is not set
# CONFIG_NFSD is not set
# CONFIG_CIFS is not set

# ── No GUI ────────────────────────────────────────────────────────────
# CONFIG_SOUND is not set
# CONFIG_DRM_AMDGPU is not set
# CONFIG_DRM_I915 is not set

# ── Scheduler tuned for steady throughput ────────────────────────────
CONFIG_HZ_250=y
CONFIG_HZ=250
CONFIG_PREEMPT_NONE=y                   # router workload is non-interactive
# CONFIG_PREEMPT_VOLUNTARY is not set
# CONFIG_PREEMPT is not set
