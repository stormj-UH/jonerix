#
# config/kernel/profile/minimal.config — bare-VM / container-guest profile.
#
# Target: cloud VMs and recovery-image kernels.  Everything below
# what jonerix actually uses; rely on the kernel's defconfig (and
# this distro's base.config) for "must boot" stuff and add nothing
# beyond serial console + virtio + bare networking.
#

# ── No bells and whistles ─────────────────────────────────────────────
# CONFIG_SOUND is not set
# CONFIG_DRM_AMDGPU is not set
# CONFIG_DRM_I915 is not set
# CONFIG_DRM_NOUVEAU is not set
# CONFIG_USB_HID is not set
# CONFIG_WIRELESS is not set
# CONFIG_BT is not set
# CONFIG_WIMAX is not set

# ── No build-host bloat ───────────────────────────────────────────────
# CONFIG_BTRFS_FS is not set              # ext4 + overlayfs is enough
# CONFIG_F2FS_FS is not set
# CONFIG_NFS_FS is not set
# CONFIG_CIFS is not set
# CONFIG_FUSE_FS=m                         # in base.config — leave alone

# ── Only the netfilter you genuinely need to ping ────────────────────
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=m
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=m
CONFIG_NETFILTER_XT_TARGET_LOG=m
CONFIG_NF_TABLES=m
CONFIG_NF_TABLES_INET=m
# Nothing else — no NAT, no masquerade, no advanced routing on a
# leaf cloud VM.

# ── No kernel-side tunneling ──────────────────────────────────────────
# CONFIG_WIREGUARD is not set
# CONFIG_GENEVE is not set
# CONFIG_VXLAN is not set
# CONFIG_L2TP is not set

# ── Light scheduler / timer settings ──────────────────────────────────
CONFIG_HZ_100=y
# CONFIG_HZ_250 is not set
# CONFIG_HZ_1000 is not set
CONFIG_HZ=100                           # power-friendly idle on cloud billing
CONFIG_PREEMPT_NONE=y
# CONFIG_PREEMPT_VOLUNTARY is not set
# CONFIG_PREEMPT is not set

# ── Disable everything graphical ──────────────────────────────────────
# CONFIG_FB_BOOT_VESA_SUPPORT is not set
# CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY is not set
CONFIG_VGA_CONSOLE=n

# ── Random/entropy on a VM ────────────────────────────────────────────
CONFIG_HW_RANDOM_VIRTIO=y
