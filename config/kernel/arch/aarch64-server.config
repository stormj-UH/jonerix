#
# config/kernel/arch/aarch64-server.config — generic aarch64 server.
#
# Targets cloud VMs (AWS Graviton, Oracle Ampere A1, Hetzner ARM,
# GCP T2A) and bare-metal Ampere/Marvell-class servers.  Use against
# mainline Linux (not the raspberrypi tree); start from
# `make ARCH=arm64 defconfig`.
#

CONFIG_64BIT=y
CONFIG_ARM64=y
CONFIG_ARM64_VA_BITS_48=y
CONFIG_ARM64_PAGE_SHIFT=12              # 4K — server VMs assume 4K pages
CONFIG_ARM64_PSEUDO_NMI=y
CONFIG_ARM64_PA_BITS_48=y
CONFIG_HOTPLUG_CPU=y

# ── Interrupt / firmware ──────────────────────────────────────────────
CONFIG_ARM_PSCI=y
CONFIG_ARM_PSCI_FW=y
CONFIG_ARM_GIC_V3=y
CONFIG_ARM_GIC_V3_ITS=y
CONFIG_ARM_SDE_INTERFACE=y              # Ampere / RAS error reporting

# ── ACPI (cloud VMs use ACPI tables, not device trees) ────────────────
CONFIG_ACPI=y
CONFIG_ACPI_REDUCED_HARDWARE_ONLY=n
CONFIG_ACPI_NUMA=y

# ── NUMA (Graviton 2/3 + Ampere Altra have multi-socket variants) ────
CONFIG_NUMA=y
CONFIG_NUMA_BALANCING=y

# ── PCIe ──────────────────────────────────────────────────────────────
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y               # generic ECAM controller
CONFIG_PCIE_DW_HOST=y                   # Designware (AWS Graviton uses this)
CONFIG_PCIEPORTBUS=y
CONFIG_PCIEAER=y

# ── Virtio guest ──────────────────────────────────────────────────────
# Every cloud VM is a virtio guest.  Build IN (=y) not =m so the
# kernel boots without an initramfs that loads virtio-blk before
# rootfs mount.
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_VSOCKETS=m
CONFIG_VIRTIO_FS=m
CONFIG_VIRTIO_PMEM=m
CONFIG_VIRTIO_INPUT=m
CONFIG_DRM_VIRTIO_GPU=m
CONFIG_VSOCKETS=y
CONFIG_VHOST=m
CONFIG_VHOST_NET=m
CONFIG_VHOST_VDPA=m

# ── KVM host (allows nested virt — disabled on AWS Nitro by default,
#               works on bare-metal Ampere) ─────────────────────────────
CONFIG_KVM=m
CONFIG_VFIO=m
CONFIG_VFIO_PCI=m

# ── Networking — common server NICs ───────────────────────────────────
CONFIG_ENA=m                            # AWS Elastic Network Adapter
CONFIG_GVE=m                            # GCP Virtual NIC
CONFIG_HV_NETVSC=m                      # Azure synthetic NIC (Hyper-V)
CONFIG_THUNDERX_NICVF=m                 # Marvell ThunderX2
CONFIG_NET_VENDOR_INTEL=y
CONFIG_E1000=m
CONFIG_IGB=m
CONFIG_IXGBE=m
CONFIG_I40E=m
CONFIG_NET_VENDOR_MELLANOX=y
CONFIG_MLX4_EN=m
CONFIG_MLX5_CORE=m
CONFIG_MLX5_CORE_EN=y

# ── NVMe (cloud SSDs, NVMe-over-PCIe) ─────────────────────────────────
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_CORE=y
CONFIG_NVME_TCP=m
CONFIG_NVME_RDMA=m
CONFIG_NVME_FABRICS=m

# ── Hyper-V (Azure / WSL2) ────────────────────────────────────────────
CONFIG_HYPERV=m
CONFIG_HYPERV_TIMER=y
CONFIG_HYPERV_UTILS=m
CONFIG_HYPERV_BALLOON=m

# ── Console — serial console for headless cloud ──────────────────────
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_SERIAL_8250=y                    # x86-compat serial on some emulated boards
CONFIG_SERIAL_8250_CONSOLE=y

# ── Crypto accel ──────────────────────────────────────────────────────
CONFIG_CRYPTO_AES_ARM64_CE=y
CONFIG_CRYPTO_AES_ARM64_CE_BLK=y
CONFIG_CRYPTO_AES_ARM64_NEON_BLK=y
CONFIG_CRYPTO_CHACHA20_NEON=y
CONFIG_CRYPTO_SHA2_ARM64_CE=y
CONFIG_CRYPTO_GHASH_ARM64_CE=y

# ── No graphics / sound / Pi-specific drivers ────────────────────────
# CONFIG_SND is not set
# CONFIG_BRCMFMAC is not set
# CONFIG_DRM_VC4 is not set
# CONFIG_RASPBERRYPI_FIRMWARE is not set
