#
# config/kernel/arch/aarch64-pi5.config — Raspberry Pi 5 (BCM2712).
#
# Use against the raspberrypi/linux tree (`rpi-6.18.y` or later)
# starting from `make ARCH=arm64 bcm2712_defconfig`.  Mainline
# kernels are catching up but Broadcom drivers still ship via the
# Pi foundation kernel as of mid-2026.
#

CONFIG_64BIT=y
CONFIG_ARM64=y

# ── ARM 64-bit baseline ───────────────────────────────────────────────
CONFIG_ARM64_VA_BITS_48=y
CONFIG_ARM64_PAGE_SHIFT=14              # 16K pages — matches the Pi 5 stock
                                        # kernel (kernel_2712.img is -v8-16k+).
                                        # Set to 12 (4K) only if you've a
                                        # specific reason; mismatches will
                                        # silently corrupt mmap-heavy apps.
CONFIG_ARM64_PSEUDO_NMI=y
CONFIG_ARM64_PA_BITS_48=y
CONFIG_HOTPLUG_CPU=y

CONFIG_ARM_PSCI=y
CONFIG_ARM_PSCI_FW=y
CONFIG_ARM_GIC_V3=y
CONFIG_ARM_GIC_V3_ITS=y

CONFIG_ARM_CPU_SUSPEND=y
CONFIG_ARM64_AMU_EXTN=y                 # CPU usage counter via /sys

# ── BCM2712 SoC platform ──────────────────────────────────────────────
CONFIG_ARCH_BCM=y
CONFIG_ARCH_BCM2835=y                   # Pi family — kept on for the rpi-tree
CONFIG_ARCH_BCMBCA=y

CONFIG_PINCTRL_BCM2835=y
CONFIG_PINCTRL_RP1=y                    # Pi 5 south-bridge

# Mailbox + firmware interface (rpi-eeprom, vcgencmd, pi5-fw).
CONFIG_RASPBERRYPI_FIRMWARE=y
CONFIG_BCM2835_MBOX=y

# Voltage / current monitor (under /sys).
CONFIG_RASPBERRYPI_HWMON=y

# ── Clocks / power ────────────────────────────────────────────────────
CONFIG_CLK_RASPBERRYPI=y
CONFIG_COMMON_CLK_RP1=y                 # Pi 5 RP1 chip
CONFIG_BCM2835_THERMAL=y
CONFIG_BCM2835_RNG=y                    # built-in RNG, no need for haveged

# ── PCIe (the RP1 sits on PCIe 0; NVMe HATs use PCIe 1) ──────────────
CONFIG_PCI=y
CONFIG_PCIE_BRCMSTB=y
CONFIG_PCIE_RCAR_HOST=n

# ── SD / eMMC ─────────────────────────────────────────────────────────
CONFIG_MMC=y
CONFIG_MMC_BCM2835=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_IPROC=y
CONFIG_MMC_SDHCI_BRCMSTB=y

# ── USB ───────────────────────────────────────────────────────────────
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=y
CONFIG_USB_DWC2=y                       # Pi 5 has DWC2 USB-C
CONFIG_USB_STORAGE=y

# ── Networking (Ethernet) ─────────────────────────────────────────────
CONFIG_NET_VENDOR_BROADCOM=y
CONFIG_BCMGENET=y                       # 1Gb Ethernet on Pi 5
CONFIG_BROADCOM_PHY=y

# Disable Energy Efficient Ethernet by default — see the
# raspi5-fixups disable-eee init script for the runtime quirks
# this driver pair hits.
#CONFIG_BROADCOM_PHY_EEE=n              # only in some out-of-tree forks

# ── Wireless (Cypress 4345 / Broadcom 43455) ──────────────────────────
CONFIG_CFG80211=y
CONFIG_MAC80211=m
CONFIG_BRCMFMAC=m
CONFIG_BRCMFMAC_SDIO=y
CONFIG_BRCMFMAC_PCIE=y
CONFIG_BRCMFMAC_USB=n
CONFIG_RFKILL=y

# ── Bluetooth (off by default — flip to =m if you want it) ────────────
# CONFIG_BT is not set

# ── Display / graphics ─────────────────────────────────────────────────
# Pi 5 has VideoCore VII GPU.  DRM enables HDMI output.
CONFIG_DRM=m
CONFIG_DRM_VC4=m
CONFIG_DRM_VC4_HDMI_CEC=y

# ── Audio (off — server installs don't need it) ───────────────────────
# CONFIG_SND is not set
# CONFIG_SND_BCM2835 is not set

# ── I2C / SPI / GPIO — what HATs and sensors talk on ─────────────────
CONFIG_I2C=y
CONFIG_I2C_BCM2835=y
CONFIG_SPI=y
CONFIG_SPI_BCM2835=y
CONFIG_GPIOLIB=y
CONFIG_GPIO_RASPBERRYPI_EXP=y
CONFIG_GPIO_BCM_VIRT=y                  # the /dev/gpiochip0 ABI

# ── Crypto accel — ARMv8 has AES, SHA, GCM in silicon ────────────────
CONFIG_CRYPTO_AES_ARM64_CE=y
CONFIG_CRYPTO_AES_ARM64_CE_CCM=y
CONFIG_CRYPTO_AES_ARM64_CE_BLK=y
CONFIG_CRYPTO_AES_ARM64_NEON_BLK=y
CONFIG_CRYPTO_CHACHA20_NEON=y
CONFIG_CRYPTO_SHA1_ARM64_CE=y
CONFIG_CRYPTO_SHA2_ARM64_CE=y
CONFIG_CRYPTO_SHA512_ARM64_CE=y
CONFIG_CRYPTO_GHASH_ARM64_CE=y
CONFIG_CRYPTO_POLY1305_NEON=y

# ── Disable a few drivers that have no place on a Pi 5 ────────────────
# CONFIG_X86 is not set
# CONFIG_ACPI is not set
# CONFIG_PCI_HOST_GENERIC is not set    # Pi 5 uses BCMSTB, not generic
