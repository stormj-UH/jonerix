#
# config/kernel/arch/x86_64.config — Intel / AMD x86_64 baseline.
#
# Targets desktop PCs, servers, cloud VMs.  Adds chip-feature flags
# the upstream `make x86_64_defconfig` doesn't always pin, plus the
# virtio drivers that every cloud VM needs.
#

CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_X86_X2APIC=y
CONFIG_X86_PAT=y

# ── CPU features — modern Intel/AMD baseline ─────────────────────────
CONFIG_X86_MCE=y
CONFIG_X86_MCE_INTEL=y
CONFIG_X86_MCE_AMD=y
CONFIG_RETPOLINE=y                      # Spectre v2 mitigation
CONFIG_PAGE_TABLE_ISOLATION=y           # Meltdown mitigation
CONFIG_GDS_FORCE_MITIGATION=y           # Downfall mitigation default

# ── Microcode loading ─────────────────────────────────────────────────
CONFIG_MICROCODE=y
CONFIG_MICROCODE_INTEL=y
CONFIG_MICROCODE_AMD=y

# ── IOMMU — required for PCI passthrough and kernel-mode DMA isolation ─
CONFIG_INTEL_IOMMU=y
CONFIG_AMD_IOMMU=y
CONFIG_INTEL_IOMMU_DEFAULT_ON=y
CONFIG_INTEL_IOMMU_SVM=y                # shared virtual addressing
CONFIG_IRQ_REMAP=y

# ── KVM host (allows the box to run VMs) ──────────────────────────────
CONFIG_KVM=m
CONFIG_KVM_INTEL=m
CONFIG_KVM_AMD=m
CONFIG_KVM_INTEL_PROVE_VE=n
CONFIG_VHOST=m
CONFIG_VHOST_NET=m
CONFIG_VHOST_VSOCK=m
CONFIG_VFIO=m                           # PCI passthrough into VMs

# ── Virtio guest — makes any jonerix x86_64 image work as a cloud VM ─
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y                     # virtio-blk root device
CONFIG_VIRTIO_NET=y                     # virtio-net NIC
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_INPUT=y
CONFIG_VIRTIO_VSOCKETS=m
CONFIG_VIRTIO_FS=m                      # virtiofs — for /workspace shares
CONFIG_VHOST_VDPA=m
CONFIG_VSOCKETS=y
CONFIG_VSOCKETS_DIAG=y                  # ss -K shows AF_VSOCK
CONFIG_DRM_VIRTIO_GPU=m

# ── Crypto accel ──────────────────────────────────────────────────────
CONFIG_CRYPTO_AES_NI_INTEL=y            # AES-NI: ~10x AES speedup
CONFIG_CRYPTO_SHA256_SSSE3=y
CONFIG_CRYPTO_SHA512_SSSE3=y
CONFIG_CRYPTO_GHASH_CLMUL_NI_INTEL=m    # GCM offload — TLS handshake hot path

# ── ACPI (every modern x86 needs it) ─────────────────────────────────
CONFIG_ACPI=y
CONFIG_ACPI_BUTTON=y
CONFIG_ACPI_AC=y
CONFIG_ACPI_BATTERY=y                   # laptops only — harmless on servers
CONFIG_ACPI_FAN=y
CONFIG_ACPI_THERMAL=y
CONFIG_ACPI_NUMA=y
CONFIG_PCI=y
CONFIG_PCIEPORTBUS=y
CONFIG_PCIEAER=y
CONFIG_PCIE_PME=y

# ── Console — serial first, framebuffer second ───────────────────────
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_PCI=y
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y            # works on cloud VMs with virtio-gpu

# ── NUMA — multi-socket servers ───────────────────────────────────────
CONFIG_NUMA=y
CONFIG_NUMA_BALANCING=y
CONFIG_NUMA_BALANCING_DEFAULT_ENABLED=y
