{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

    "logo": {
        "type": "file",
        "source": "/etc/fastfetch/logo.txt",
        "color": {
            "1": "blue",
            "2": "black",
            "3": "yellow",
            "4": "white"
        },
        "padding": {
            "top": 0,
            "left": 1,
            "right": 2
        }
    },

    "display": {
        "separator": " -> ",
        "color": {
            "keys": "cyan",
            "title": "blue"
        }
    },

    "modules": [
        "title",
        "separator",
        "os",
        "kernel",
        "uptime",
        {
            "type": "command",
            "key": "Packages",
            "text": "echo $(ls -d /var/db/jpkg/installed/*/ 2>/dev/null | grep -c /) '(jpkg)'"
        },
        "shell",
        "terminal",
        {
            "type": "command",
            "key": "Editor",
            "text": "readlink /bin/editor 2>/dev/null || echo toybox"
        },
        "cpu",
        "memory",
        "disk",
        "localip",
        "break",
        "colors"
    ]
}
