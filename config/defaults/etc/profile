# /etc/profile — jonerix system-wide login profile
# Sourced by login shells. Keep this POSIX-compatible.

# --- PATH ---
# jonerix is merged-usr-flat: /usr is a runtime symlink to / and every
# package installs straight into /bin and /lib.  There is no
# /usr/local/bin (that was a vestige of the FHS multi-prefix layout)
# and no /sbin (packages that need iptables-style compat symlinks
# plant them only when their consumer — e.g. docker — is installed).
#
# User-specific binaries go in ~/bin; that's picked up via the
# per-user .profile / .brashrc / .zshrc layer, not here.
export PATH="/bin"

# --- Prompt ---
# zsh: handled by /etc/zshrc
# POSIX sh / toybox
if [ -z "$ZSH_VERSION" ]; then
    # $HOSTNAME isn't exported by every shell we run under (mksh on WSL
    # in particular starts with it unset), so derive it from the kernel
    # before wiring it into PS1 — otherwise the prompt renders as a
    # naked ":/root#".
    [ -z "$HOSTNAME" ] && HOSTNAME=$(hostname 2>/dev/null)
    export HOSTNAME

    if [ "$(id -u)" -eq 0 ]; then
        PS1='$HOSTNAME:$PWD# '
    else
        PS1='$(whoami)@$HOSTNAME:$PWD$ '
    fi
    export PS1
fi

# --- Umask ---
# 022: owner rwx, group r-x, other r-x
umask 022

# --- Locale ---
export CHARSET="UTF-8"
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# --- Editor ---
export EDITOR="pico"
export VISUAL="pico"
export PAGER="less"

# --- Aliases ---
alias ls='ls --color=auto'
alias ll='ls -la'
alias la='ls -A'
alias l='ls -CF'
alias grep='grep --color=auto'
alias ..='cd ..'
alias ...='cd ../..'

# --- History ---
export HISTSIZE=1000
export HISTFILE="$HOME/.sh_history"

# --- Misc ---
# Prevent core dumps by default
ulimit -c 0

# Source user-specific profile if present
if [ -f "$HOME/.profile" ]; then
    . "$HOME/.profile"
fi
