# jonerix:all — Complete image with every package + Claude Code
#
# Starts from jonerix-develop and adds all remaining tools.
# All packages built from source on jonerix with permissive tools.
#
# Build: docker build -f Dockerfile.all --tag jonerix:all --platform linux/arm64 .

ARG BASE=jonerix-develop:latest
FROM ${BASE}

# Update jpkg binary to latest (fixes install path bugs)
COPY bin/jpkg-aarch64 /bin/jpkg

# Install additional packages not in the develop image
# Force reinstall zsh (develop image has stale metadata but missing binary)
RUN jpkg update && \
    rm -rf /var/db/jpkg/installed/zsh 2>/dev/null && \
    for pkg in zsh byacc ripgrep containerd runc nerdctl cni-plugins micro nghttp2; do \
        echo "Installing $pkg..." && \
        jpkg install $pkg || echo "FAILED: $pkg"; \
    done

# libatomic — needed by Node 24 on aarch64 (V8 atomic ops).
# Built from compiler-rt source (Apache-2.0). Installed via jpkg.
RUN rm -rf /var/db/jpkg/installed/libatomic 2>/dev/null && \
    jpkg install libatomic || echo "libatomic: manual fallback" && \
    if [ ! -f /lib/libatomic.so.1 ]; then \
        ln -sf libatomic.so /lib/libatomic.so.1 2>/dev/null || true; \
    fi

# Standard symlinks
RUN ln -sf byacc /bin/yacc 2>/dev/null || true && \
    ln -sf nerdctl /bin/docker 2>/dev/null || true && \
    # zsh as default shell + bash compatibility
    ln -sf zsh /bin/bash 2>/dev/null || true

# Install Claude Code via npm (uses Node.js already in image, ~47MB JS)
RUN npm install -g @anthropic-ai/claude-code && \
    echo "Claude Code installed via npm"

ENV EDITOR=micro
ENV VISUAL=micro
ENV SHELL=/bin/zsh
ENV LANG=C.UTF-8

WORKDIR /root
ENTRYPOINT ["/bin/zsh"]
CMD ["-l"]
