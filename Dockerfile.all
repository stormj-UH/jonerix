# jonerix:all — Complete image with every package + Claude Code
#
# Starts from jonerix-develop and adds all remaining tools.
# All packages built from source on jonerix with permissive tools.
#
# Build: docker build -f Dockerfile.all --tag jonerix:all --platform linux/arm64 .

ARG BASE=jonerix-develop:latest
FROM ${BASE}

# Install additional packages not in the develop image
RUN jpkg update 2>/dev/null || true && \
    for pkg in zsh byacc ripgrep containerd runc nerdctl cni-plugins micro nghttp2; do \
        jpkg install $pkg 2>/dev/null || echo "SKIP: $pkg"; \
    done

# libatomic.so.1 — needed by Node 24 on aarch64 (V8 atomic ops).
# The real libatomic comes from GCC runtime (libgcc package).
# If not present, check if llvm's compiler-rt provides it.
RUN if [ ! -f /lib/libatomic.so.1 ]; then \
        # Try to find it in the LLVM/GCC runtime dirs
        for f in /lib/gcc/*/libatomic.so.1 /lib/libgcc/libatomic.so.1; do \
            [ -f "$f" ] && cp "$f" /lib/libatomic.so.1 && break; \
        done; \
        # If still missing, create a proper one using clang's built-in atomics
        if [ ! -f /lib/libatomic.so.1 ]; then \
            cat > /tmp/atomic.c << 'ATOMICSRC'
#include <stdint.h>
#include <stddef.h>
#define ATOMIC_OP(size, type) \
  type __atomic_load_##size(const volatile void *ptr, int mo) { return __atomic_load_n((const volatile type *)ptr, mo); } \
  void __atomic_store_##size(volatile void *ptr, type val, int mo) { __atomic_store_n((volatile type *)ptr, val, mo); } \
  type __atomic_exchange_##size(volatile void *ptr, type val, int mo) { return __atomic_exchange_n((volatile type *)ptr, val, mo); } \
  int __atomic_compare_exchange_##size(volatile void *ptr, void *expected, type desired, int success, int failure) { return __atomic_compare_exchange_n((volatile type *)ptr, (type *)expected, desired, 0, success, failure); }
ATOMIC_OP(1, uint8_t)
ATOMIC_OP(2, uint16_t)
ATOMIC_OP(4, uint32_t)
ATOMIC_OP(8, uint64_t)
ATOMICSRC
            cc -shared -O2 -o /lib/libatomic.so.1 /tmp/atomic.c 2>/dev/null && \
            ln -sf libatomic.so.1 /lib/libatomic.so && \
            rm -f /tmp/atomic.c; \
        fi; \
    fi

# Standard symlinks
RUN ln -sf byacc /bin/yacc 2>/dev/null || true && \
    ln -sf nerdctl /bin/docker 2>/dev/null || true && \
    # zsh as default shell + bash compatibility
    ln -sf zsh /bin/bash 2>/dev/null || true

# Install Claude Code (native musl binary, no npm needed)
RUN ARCH=$(uname -m); \
    case $ARCH in \
        aarch64) P="linux-arm64-musl";; \
        x86_64)  P="linux-x64-musl";; \
        *) P="";; \
    esac; \
    if [ -n "$P" ]; then \
        GCS="https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases"; \
        VER=$(curl -fsSL "$GCS/latest" 2>/dev/null); \
        if [ -n "$VER" ]; then \
            mkdir -p /root/.claude && \
            curl -fsSL "$GCS/$VER/$P/claude" -o /root/.claude/claude && \
            chmod +x /root/.claude/claude && \
            ln -sf /root/.claude/claude /bin/claude && \
            echo "Claude Code $VER installed"; \
        fi; \
    fi

ENV EDITOR=micro
ENV VISUAL=micro
ENV SHELL=/bin/zsh
ENV LANG=C.UTF-8

WORKDIR /root
ENTRYPOINT ["/bin/zsh"]
CMD ["-l"]
