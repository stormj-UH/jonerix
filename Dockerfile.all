# jonerix:all — Complete image with every package + Claude Code
#
# Starts from jonerix-develop and adds all remaining tools.
# All packages built from source on jonerix with permissive tools.
#
# Build: docker build -f Dockerfile.all --tag jonerix:all --platform linux/arm64 .

ARG BASE=jonerix-develop:latest
FROM ${BASE}

# Install additional packages not in the develop image
RUN jpkg update 2>/dev/null || true && \
    for pkg in zsh byacc ripgrep containerd runc nerdctl cni-plugins micro nghttp2; do \
        jpkg install $pkg 2>/dev/null || echo "SKIP: $pkg"; \
    done

# libatomic.so.1 — needed by Node 24 on aarch64.
# Build a proper libatomic from compiler-rt source using clang builtins.
RUN if [ ! -f /lib/libatomic.so.1 ]; then \
        cat > /tmp/atomic.c << 'EOF'
/* Minimal libatomic implementation using clang __atomic builtins */
#include <stdint.h>
#include <string.h>

/* Generic atomic compare-exchange — the symbol Node 24 needs */
int __atomic_compare_exchange(unsigned long size, void *ptr, void *expected,
                               void *desired, int success_order, int failure_order) {
    switch (size) {
    case 1: return __atomic_compare_exchange_n((_Atomic uint8_t *)ptr, (uint8_t *)expected, *(uint8_t *)desired, 0, success_order, failure_order);
    case 2: return __atomic_compare_exchange_n((_Atomic uint16_t *)ptr, (uint16_t *)expected, *(uint16_t *)desired, 0, success_order, failure_order);
    case 4: return __atomic_compare_exchange_n((_Atomic uint32_t *)ptr, (uint32_t *)expected, *(uint32_t *)desired, 0, success_order, failure_order);
    case 8: return __atomic_compare_exchange_n((_Atomic uint64_t *)ptr, (uint64_t *)expected, *(uint64_t *)desired, 0, success_order, failure_order);
    default: return 0;
    }
}
void __atomic_load(unsigned long size, void *ptr, void *ret, int order) {
    memcpy(ret, ptr, size);
}
void __atomic_store(unsigned long size, void *ptr, void *val, int order) {
    memcpy(ptr, val, size);
}
EOF
        cc -shared -O2 -fPIC -o /lib/libatomic.so.1 /tmp/atomic.c && \
        ln -sf libatomic.so.1 /lib/libatomic.so && \
        rm -f /tmp/atomic.c; \
    fi

# Standard symlinks
RUN ln -sf byacc /bin/yacc 2>/dev/null || true && \
    ln -sf nerdctl /bin/docker 2>/dev/null || true && \
    # zsh as default shell + bash compatibility
    ln -sf zsh /bin/bash 2>/dev/null || true

# Install Claude Code (native musl binary, no npm needed)
RUN ARCH=$(uname -m); \
    case $ARCH in \
        aarch64) P="linux-arm64-musl";; \
        x86_64)  P="linux-x64-musl";; \
        *) P="";; \
    esac; \
    if [ -n "$P" ]; then \
        GCS="https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases"; \
        VER=$(curl -fsSL "$GCS/latest" 2>/dev/null); \
        if [ -n "$VER" ]; then \
            mkdir -p /root/.claude && \
            curl -fsSL "$GCS/$VER/$P/claude" -o /root/.claude/claude && \
            chmod +x /root/.claude/claude && \
            ln -sf /root/.claude/claude /bin/claude && \
            echo "Claude Code $VER installed"; \
        fi; \
    fi

ENV EDITOR=micro
ENV VISUAL=micro
ENV SHELL=/bin/zsh
ENV LANG=C.UTF-8

WORKDIR /root
ENTRYPOINT ["/bin/zsh"]
CMD ["-l"]
