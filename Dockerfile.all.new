# jonerix:all-new — Complete image built from jonerix:minimal
#
# Installs all packages via jpkg from the local built binary.
#
# Build (aarch64): docker build -f Dockerfile.all.new --tag jonerix:all-new --platform linux/arm64 .
# Build (x86_64):  docker build -f Dockerfile.all.new --tag jonerix:all-new --platform linux/amd64 .

ARG MINIMAL_IMAGE=ghcr.io/stormj-uh/jonerix:minimal
FROM ${MINIMAL_IMAGE}

COPY packages/jpkg/jpkg /bin/jpkg

# Bootstrap bsdtar: minimal has /bin/tar→bsdtar but no bsdtar binary
# (core bsdtar is a metadata stub; the real binary comes from libarchive).
# Install a pre-built static bsdtar (libarchive 3.8.6, no OpenSSL) so that
# PAX-format archives (LLVM) extract correctly. Depends only on musl+zlib+zstd
# which are all present in the minimal image.
COPY tools/bsdtar-static-aarch64 /bin/bsdtar
RUN chmod 755 /bin/bsdtar && echo "jpkg $(jpkg --version 2>&1 | head -1)"

# Install zsh first — required as shell for jpkg build steps (commit a588005).
# Separate RUN intentionally busts the cache for the main install block below
# so the big install loop re-runs when the package repo changes.
# Fall back gracefully if zsh not yet published (404 → continue with toybox sh).
RUN jpkg update && jpkg install zsh && ln -sf zsh /bin/sh || true

# Skip stale/conflicting package artifacts until they are rebuilt:
# - libressl duplicates the current openssl package's payload
# - libarchive/bsdtar and unbound still link against missing OpenSSL 3 sonames
# - npm overlaps with nodejs' bundled npm tree
# - uutils overwrites many toybox-owned paths under /bin
RUN jpkg update && \
    for pkg in \
      musl zlib zstd lz4 xz ncurses openssl curl nghttp2 \
      toybox openrc dropbear dhcpcd doas snooze \
      ifupdown-ng mandoc pigz \
      libcxx libatomic llvm \
      cmake bmake samurai flex bc byacc \
      perl python3 pip \
      go rust \
      nodejs \
      zsh gitoxide ripgrep micro fastfetch \
      containerd runc nerdctl cni-plugins; \
    do \
      echo "Installing: $pkg" && jpkg install "$pkg" || echo "WARN: $pkg failed"; \
    done; \
    [ -x /bin/zsh ] && ln -sf zsh /bin/sh 2>/dev/null || true; \
    ln -sf clang /bin/cc 2>/dev/null || true; \
    ln -sf clang++ /bin/c++ 2>/dev/null || true; \
    ln -sf ld.lld /bin/ld 2>/dev/null || true; \
    LLVM_BIN=; \
    for d in /lib/llvm*/bin; do [ -d "$d" ] && LLVM_BIN="$d" && break; done; \
    if [ -n "$LLVM_BIN" ]; then \
      for tool in ar nm ranlib strip objcopy objdump readelf; do \
        ln -sf "$LLVM_BIN/llvm-$tool" "/bin/$tool" 2>/dev/null || true; \
        ln -sf "$LLVM_BIN/llvm-$tool" "/bin/llvm-$tool" 2>/dev/null || true; \
      done; \
    fi; \
    ln -sf bmake /bin/make 2>/dev/null || true; \
    ln -sf samu /bin/ninja 2>/dev/null || true; \
    ln -sf python3 /bin/python 2>/dev/null || true; \
    ln -sf zsh /bin/bash 2>/dev/null || true; \
    ln -sf bsdtar /bin/tar 2>/dev/null || true; \
    ln -sf byacc /bin/yacc 2>/dev/null || true; \
    ln -sf flex /bin/lex 2>/dev/null || true; \
    ln -sf micro /bin/editor 2>/dev/null || true; \
    ln -sf micro /bin/vi 2>/dev/null || true; \
    ln -sf nerdctl /bin/docker 2>/dev/null || true

ENV PATH=/bin
ENV HOME=/root
ENV SHELL=/bin/zsh
ENV TERM=xterm
ENV EDITOR=micro
ENV VISUAL=micro
ENV PAGER=less
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

WORKDIR /root
ENTRYPOINT ["/bin/zsh"]
CMD ["-l"]
