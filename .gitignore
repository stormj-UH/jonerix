.cas/
.claude/
CLAUDE.md
# Worktree-specific files (generated per worktree)
.env.worktree
# macOS Finder metadata
.DS_Store
# Python bytecode caches (we don't ship .pyc; .py is what builds reach for)
__pycache__/
*.pyc
*.pyo
# Build artifacts
node-v*.tar.gz
!sources/node-v*.tar.gz
output/
*.img
*.tar.zst
# Compiled objects
*.o
!packages/core/jpkg/vendor/**/*.o
*.d
*.dSYM/
# Exceptions: directories named *.d under config/ (these are config
# drop-in dirs — conf.d, sysctl.d, cron.d, local.d, limits.d, init.d)
# and under packages/*/*/ (per-package init.d).  Without these, the
# *.d wildcard above swallows every drop-in directory in the tree.
!config/**/*.d/
!config/**/*.d/**
!packages/*/*/init.d/
!packages/*/*/init.d/**
!packages/*/*/cron.d/
!packages/*/*/conf.d/
# Test binaries (keep .c sources)
packages/jpkg/tests/test_toml
packages/jpkg/tests/test_pkg
packages/jpkg/tests/test_deps
# packages/jpkg/jpkg — tracked: CI needs this pre-built arm64 binary
keys/jonerix.sec
# Local-build hedge directory (colima/docker artifacts, never committed)
.local-build/
