# jonerix â€” Minimal Permissive Linux Distribution
# jonerix builds jonerix: uses existing jonerix:minimal to bootstrap the next.
# Zero Alpine. Zero GPL runtime.
#
# Components (all permissively licensed):
#   jpkg           (MIT)          â€” pre-built static binary
#   musl libc      (MIT)          â€” via jpkg
#   toybox 0.8.11  (0BSD)         â€” via jpkg (includes /bin/sh)
#   bsdtar         (Apache-2.0)   â€” via jpkg (replaces toybox tar)
#   dropbear SSH   (MIT)          â€” via jpkg
#   openrc         (BSD-2-Clause) â€” via jpkg
#   libressl       (ISC)          â€” via jpkg
#   curl           (MIT)          â€” via jpkg
#   zstd           (BSD)          â€” via jpkg
#
# Build: docker build -f Dockerfile.minimal --tag jonerix-minimal:latest .

ARG BUILDER=ghcr.io/stormj-uh/jonerix:minimal

# ============================================================
# Stage 0: Build jpkg from source in Alpine
# ============================================================
FROM alpine:latest AS jpkg-builder
RUN apk add --no-cache clang lld musl-dev samurai zstd-dev zstd-static cmake make

# Build LibreSSL from source so jpkg has native TLS (no curl dependency).
# Static-only build — the resulting jpkg is fully self-contained.
RUN wget -q https://ftp.openbsd.org/pub/OpenBSD/LibreSSL/libressl-4.0.0.tar.gz && \
    tar xf libressl-4.0.0.tar.gz && cd libressl-4.0.0 && \
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr \
      -DBUILD_SHARED_LIBS=OFF -DLIBRESSL_APPS=OFF -DLIBRESSL_TESTS=OFF && \
    cmake --build build -j$(nproc) && cmake --install build && \
    cd / && rm -rf libressl-4.0.0*

COPY packages/jpkg/ /build/jpkg/
RUN cd /build/jpkg && \
    clang -std=c11 -Os -fuse-ld=lld \
      -Wall -Wextra -Wpedantic -Werror=implicit-function-declaration \
      -Wno-unused-parameter -Wshadow -Wstrict-prototypes \
      -fstack-protector-strong \
      -D_POSIX_C_SOURCE=200809L -D_DEFAULT_SOURCE -DJPKG_USE_LIBRESSL \
      -I/usr/include \
      -o jpkg src/*.c \
      -L/usr/lib -ltls -lssl -lcrypto -lzstd -static && \
    strip jpkg

# Build a static bsdtar from Alpine libarchive (works on any arch)
RUN apk add --no-cache libarchive-tools && cp /usr/bin/bsdtar /build/bsdtar && chmod 755 /build/bsdtar

# ============================================================
# Stage 1: Download + install packages using existing jonerix
# ============================================================
FROM ${BUILDER} AS rootfs

# When BUILDER is Alpine (bootstrap), install tools jpkg needs
RUN if command -v apk >/dev/null 2>&1; then apk add --no-cache curl tar zstd libarchive-tools; fi

# Create rootfs skeleton
RUN mkdir -p \
    /jonerix/etc/jpkg/keys \
    /jonerix/etc/ssl/certs \
    /jonerix/etc/dropbear \
    /jonerix/etc/init.d \
    /jonerix/etc/conf.d \
    /jonerix/etc/network \
    /jonerix/bin \
    /jonerix/lib \
    /jonerix/var/log \
    /jonerix/var/cache/jpkg \
    /jonerix/var/db/jpkg/installed \
    /jonerix/home \
    /jonerix/root \
    /jonerix/dev \
    /jonerix/proc \
    /jonerix/sys \
    /jonerix/run \
    /jonerix/tmp && \
    chmod 1777 /jonerix/tmp && chmod 700 /jonerix/root

# Configure jpkg repo
COPY config/defaults/etc/jpkg/keys/ /jonerix/etc/jpkg/keys/
RUN printf '[repo]\nurl = "https://github.com/stormj-UH/jonerix/releases/download/packages"\n' \
        > /jonerix/etc/jpkg/repos.conf

# Use freshly built jpkg â€” the BUILDER image's jpkg may have bugs.
COPY --from=jpkg-builder /build/jpkg/jpkg /bin/jpkg

# Install bsdtar from Alpine libarchive (arch-neutral, no prebuilt binary needed).
COPY --from=jpkg-builder /build/bsdtar /jonerix/bin/bsdtar
# Also install on builder PATH so jpkg can extract packages
COPY --from=jpkg-builder /build/bsdtar /bin/bsdtar

# Install all packages via jpkg (jonerix building jonerix)
# No mksh â€” toybox provides /bin/sh (POSIX shell)
RUN jpkg update && \
    jpkg --root /jonerix update && \
    jpkg --root /jonerix install \
        musl zlib toybox dropbear openrc libressl curl zstd

# Flatten usr/ into / (merged-usr layout)
RUN if [ -d /jonerix/usr ]; then \
        cp -a /jonerix/usr/. /jonerix/ && rm -rf /jonerix/usr; \
    fi && \
    ln -s / /jonerix/usr

# Essential symlinks
# toybox now includes sh applet â€” symlink /bin/sh to toybox
RUN ln -sf toybox /jonerix/bin/sh && \
    ln -sf bsdtar /jonerix/bin/tar && \
    ln -sf dbclient /jonerix/bin/ssh 2>/dev/null || true

# CA certificates (downloaded from curl.se â€” no Alpine needed)
RUN curl -fsSL https://curl.se/ca/cacert.pem -o /jonerix/etc/ssl/certs/ca-certificates.crt

# --- Default config files ---
COPY config/defaults/etc/hostname     /jonerix/etc/hostname
COPY config/defaults/etc/resolv.conf  /jonerix/etc/resolv.conf
COPY config/defaults/etc/passwd       /jonerix/etc/passwd
COPY config/defaults/etc/group        /jonerix/etc/group
COPY config/defaults/etc/shadow       /jonerix/etc/shadow
COPY config/defaults/etc/shells       /jonerix/etc/shells
COPY config/defaults/etc/profile      /jonerix/etc/profile
COPY config/defaults/etc/zshrc        /jonerix/etc/zshrc
COPY config/defaults/etc/doas.conf    /jonerix/etc/doas.conf
COPY config/defaults/etc/os-release   /jonerix/etc/os-release
COPY config/defaults/etc/fastfetch/   /jonerix/etc/fastfetch/
COPY config/defaults/etc/securetty    /jonerix/etc/securetty
COPY config/openrc/init.d/            /jonerix/etc/init.d/
RUN chmod 755 /jonerix/etc/init.d/* 2>/dev/null || true && \
    chmod 4755 /jonerix/bin/su /jonerix/bin/passwd /jonerix/bin/login 2>/dev/null || true

COPY scripts/license-audit.sh /jonerix/bin/license-audit
RUN chmod 755 /jonerix/bin/license-audit

# ============================================================
# Stage 1: Final image â€” FROM scratch, zero dependencies
# ============================================================
FROM scratch

COPY --from=rootfs /jonerix/ /

# Freshly built static jpkg binary
COPY --from=jpkg-builder /build/jpkg/jpkg /bin/jpkg

ENV PATH=/bin
ENV HOME=/root
ENV SHELL=/bin/sh
ENV TERM=xterm
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8

WORKDIR /root

CMD ["/bin/sh"]
